  <step>
    <name>FI_CONTABILIZACAO</name>
    <type>TableInput</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>SELECT
  PROCEDIMENTO
, SEQUENCIA
, TABLINK
, CODLINK
, LANCTOESTORNO
, NROEMPRESA
, FILIAL
, DEBCRED
, CTACONTABIL
, TIPOENTIDADE
, CODENTIDADE
, CENTRORESULT
, DTACONTABILIZA
, CASE 
		WHEN DEBCRED = 'D'
			THEN (VALOR * - 1)
		ELSE (VALOR)
		END AS VALOR
, HISTORICO
, DTAGEROUCTB
, LINKCTB
, PROCESSOCTB
, NROPROCESSO
, SITUACAO
, MENSERRO
, OBRIGDIREITO
, OPCANCELADA
, DTACANCELOU
, USUCANCELOU
, CODESPECIE
, CODOPERACAO
, SEQLANCTO
, DTAALTERACAO
, USUALTERACAO
, NRODOCUMENTO
, CODIGOFINANCEIRO
FROM CONSINCO.FI_CONTABILIZACAO
WHERE 
  (TRUNC(DTACONTABILIZA) BETWEEN '01-JAN-21' AND '31-MAI-22')
AND
    (OPCANCELADA IS NULL OR OPCANCELADA = 'N')
AND
    SUBSTR(CTACONTABIL,1,1) = '3' 
--AND
--    NROEMPRESA = 998
</sql>
