  <step>
    <name>CTV_LANCAMENTO</name>
    <type>TableInput</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>SELECT  
  NROEMPRESA
, DTALANCAMENTO
, FILIAL
	,CASE 
		WHEN CONTADB &lt;&gt; 0
			THEN (VALOR * - 1)
		ELSE (VALOR)
		END AS VALOR
, HISTORICO
, PROCESSOCTB
	,CASE 
		WHEN CONTADB &lt;&gt; 0
			THEN CONTADB
		ELSE CONTACR
		END AS XX_CONTA
FROM CONSINCO.CTV_LANCAMENTO A
WHERE DTACANCELOU IS NULL
	AND (
		SUBSTR(TO_CHAR(CONTADB), 1, 1) = '3'
		OR SUBSTR(TO_CHAR(CONTACR), 1, 1) = '3'
		)
	AND TRUNC(DTALANCAMENTO) BETWEEN '01-JAN-21' AND '31-MAI-22'
	--AND NROEMPRESA IN (998)
	AND LOTE &lt;&gt; 912
	AND ORIGEM = 'FI'
</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
