  <step>
    <name>ESPECIE para FI</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>/*
Trazer as ESPECIES para os FI que as possuem.
*/

SELECT DISTINCT 
	  NROPROCESSO
	, A.FILIAL
	, B.CODESPECIE
	, B.DESCRICAO 
	, A.HISTORICO
    , A.VALOR
FROM CONSINCO.FI_CONTABILIZACAO A
INNER JOIN CONSINCO.MRL_ESPECIEFIN B ON A.CODESPECIE = B.CODESPECIE
AND 
  (TRUNC(DTACONTABILIZA) >= '01-JAN-21')
AND
  DTACANCELOU IS NULL
AND 
  SUBSTR(TO_CHAR(CTACONTABIL),1,1) = '3'
AND
  NROEMPRESA IN (6,998)
</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
      <value-meta>
