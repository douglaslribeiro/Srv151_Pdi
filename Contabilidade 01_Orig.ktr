  <step>
    <name>FISCAL - NATUREZA</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>BI_207</connection>
    <sql>--SELECT HISTORICOPADRAO FROM dbo.fat_lancamentos_ct WHERE HISTORICOPADRAO LIKE '%Outros Documentos e Opera%'

UPDATE dbo.fat_lancamentos_ct SET HISTORICOPADRAO = '0' WHERE HISTORICOPADRAO LIKE '%Outros Documentos e Opera%' AND ORIGEM = 'F';

SELECT DISTINCT
  LANCAMENTO
, REPLACE((REPLACE(HISTORICOPADRAO,'Contabilização Fiscal. Modelo: ','')),'.','') AS CGO
FROM dbo.fat_lancamentos_ct
WHERE
	ORIGEM = 'F'
--AND
	--NROEMPRESA &lt;&gt; 6
;</sql>
