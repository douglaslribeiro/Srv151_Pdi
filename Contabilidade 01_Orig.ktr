  <step>
    <name>FINANCEIRO - FI_CONTABILIZACAO *</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>SELECT DISTINCT
  NROPROCESSO
, MAX(CODOPERACAO) AS CODOPERACAO
FROM CONSINCO.FI_CONTABILIZACAO
WHERE 
  (TRUNC(DTACONTABILIZA) >= '01-JAN-21')
AND
--  (OPCANCELADA IS NULL OR OPCANCELADA = 'N')
(OPCANCELADA IS NULL OR OPCANCELADA &lt;&gt; 'S')
AND
    SUBSTR(CTACONTABIL,1,1) = '3' 
--AND	DTACANCELOU IS NULL
--- USO PARA TESTE. APAGAR
--AND CODOPERACAO = 910 AND VALOR = 1175
---

GROUP BY
	NROPROCESSO
</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
