  <step>
    <name>Calendario 242</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>WITH DimCalendario AS (
    SELECT
        TO_DATE('01-01-2020', 'DD-MM-YYYY') + LEVEL - 1 AS Data
    FROM dual
    --CONNECT BY TO_DATE('01-01-2020', 'DD-MM-YYYY') + LEVEL - 1 &lt;=  ADD_MONTHS(SYSDATE, 24)
      CONNECT BY LEVEL &lt;= TO_DATE('31-12-' || TO_CHAR(ADD_MONTHS(SYSDATE, 24), 'YYYY'), 'DD-MM-YYYY') 
                    - TO_DATE('01-01-2020', 'DD-MM-YYYY') + 1
)
SELECT
    data as dta,
    ADD_MONTHS(Data, -12) + (TO_NUMBER(TO_CHAR(Data, 'D')) - TO_NUMBER(TO_CHAR(ADD_MONTHS(Data, -12), 'D'))) AS DataAnoAnterior, -- Dia equivalente no ano anterior com o mesmo dia da semana
    EXTRACT(DAY FROM Data) AS NroDia,
    EXTRACT(MONTH FROM Data) AS NroMes,
    EXTRACT(YEAR FROM Data) AS NroAno,   
    TO_NUMBER(TO_CHAR(Data, 'WW')) AS NroSemana_Ano, -- Número Semana do ano
    TO_NUMBER(TO_CHAR(Data, 'D')) AS NroDiaSemana, -- Número do dia da semana (1=Domingo, 7=Sábado)
    TO_CHAR(Data, 'FMDay') AS NomeDiaSemana, -- Nome do dia da semana 
    TO_CHAR(Data, 'Month') AS NomeMes, -- Nome do mês
    TO_CHAR(Data, 'Mon') AS MesAbrev, -- Nome do mês abreviado
    TO_CHAR(Data, 'YYYY-MM') AS AnoMes, -- Ano e Mês no formato 'YYYY-MM'
    CASE 
        WHEN EXTRACT(MONTH FROM Data) BETWEEN 1 AND 6 THEN '1º Semestre' 
        ELSE '2º Semestre' 
    END AS Semestre, -- Semestre do ano
    CASE 
        WHEN EXTRACT(MONTH FROM Data) BETWEEN 1 AND 3 THEN '1º Trimestre'
        WHEN EXTRACT(MONTH FROM Data) BETWEEN 4 AND 6 THEN '2º Trimestre'
        WHEN EXTRACT(MONTH FROM Data) BETWEEN 7 AND 9 THEN '3º Trimestre'
        ELSE '4º Trimestre'
    END AS Trimestre, -- Trimestre do ano
    CASE 
        WHEN EXTRACT(MONTH FROM Data) BETWEEN 1 AND 2 THEN '1º Bimestre'
        WHEN EXTRACT(MONTH FROM Data) BETWEEN 3 AND 4 THEN '2º Bimestre'
        WHEN EXTRACT(MONTH FROM Data) BETWEEN 5 AND 6 THEN '3º Bimestre'
        WHEN EXTRACT(MONTH FROM Data) BETWEEN 7 AND 8 THEN '4º Bimestre'
        WHEN EXTRACT(MONTH FROM Data) BETWEEN 9 AND 10 THEN '5º Bimestre'
        ELSE '6º Bimestre'
    END AS Bimestre, -- Bimestre do ano
    TRUNC(Data, 'MM') AS PrimeiroDiaDoMes, -- Primeiro dia do mês
    LAST_DAY(Data) AS UltimoDiaDoMes, -- Último dia do mês,
            CASE 
            WHEN TO_CHAR(Data, 'D') = 1 THEN 'Início'
            WHEN TO_CHAR(Data, 'D') = 7 THEN 'Fim'
            ELSE NULL
        END AS inicio_fim_semana
FROM DimCalendario
</sql>
