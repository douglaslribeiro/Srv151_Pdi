    </partitioning>
    <connection>238_intranet</connection>
    <sql>with funcionarios as
     (select
         a.*,
         b.*,
         (
           select
             numero
           from
             tbdocumentopessoa
           where
             idpessoa                = a.idpessoa
           and iddocumentopessoatipo = 1) cpf,
                    (
           select
             numero
           from
             tbdocumentopessoa
           where
             idpessoa                = a.idpessoa
           and iddocumentopessoatipo = 6) pis
       from
         tbpessoa      a,
         tbfuncionario b
       where
         a.idpessoa = b.idpessoa
      --and coalesce(a.ininativo, false) is false
      -- and b.dtdemissao is null 
       )
select
  REPLACE(REPLACE(REPLACE(UNACCENT(b.setor), '  ', ' '), CHR(13), ''), CHR(10), '') as Setor,
  REPLACE(REPLACE(REPLACE(UNACCENT(c.funcao), '  ', ' '), CHR(13), ''), CHR(10), '') as Funcao, 
  a.*,
          --CASE
            --WHEN dtadmissao IS NOT NULL AND dtdemissao IS NULL THEN 'Ativo'
            --WHEN dtadmissao IS NOT NULL AND dtdemissao IS NOT NULL THEN 'Desligado'
            --ELSE 'Status Indefinido'
        --END AS status
         --CASE
              --WHEN dtdemissao IS NULL THEN 'ATIVO' -- Funcionários que não possuem data de demissão
              --WHEN dtdemissao IS NOT NULL THEN 'DESLIGADO' -- Funcionários que possuem data de demissão
              --ELSE 'Status Indefinido' -- Caso alguma outra condição imprevista ocorra
         --END AS status
   CASE
   WHEN
      A.ininativo = FALSE
   THEN
      'ATIVO'
   ELSE
      'DESLIGADO'--TRUE = 'DESLIGADO'
   END AS status
from
  funcionarios a
left join
  tbfuncionariosetor b
on
  a.idsetor = b.idfuncionariosetor
left join tbfuncionariofuncao c
	on a.idfuncao = c.idfuncionariofuncao
--where  idsetor= 547
--order by
--dtdemissao --desc</sql>
