  <step>
    <name>max_codgeraloper</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>select
   codgeraloper                                  ,
   tipcgo                                        ,
   decode(tipcgo,
          'S'   ,'SAIDA'  ,
          'E'   ,'ENTRADA',
          tipcgo)AS DESCtipcgo,
   tipuso                     ,
   decode( tipuso,
           'E'   ,'EMISSAO DE NF'   ,
           'R'   ,'RECEBIMENTO'     ,
           'I'   ,'OPERACAO INTERNA',
           tipuso) AS DESCtipuso,
   tipdocfiscal                 ,
   descricao                    ,
   aplicacao                    ,
   gertitfinanceiro             ,
   gerlivrofiscal               ,
   geralteracaoestq             ,
   geralteracaoestqfisc         ,
   recalcusmedio                ,
   acmcompravenda               ,
   acmoutraentsai               ,
   exgpedidocompra              ,
   tippedidocompra              ,
   tiprecebpedido               ,
   tipacumulocus                ,
   solperdesctransf             ,
   obspadraolf                  ,
   modelonf                     ,
   descricaonf                  ,
   tipclassinterno              ,
   decode(tipclassinterno,
          'N'            ,'NORMAL'         ,
          'C'            ,'CONSUMO PROPRIO',
          'P'            ,'PERDA OU QUEBRA',
          'R'            ,'FURTO OU ROUBO' ,
          'A'            ,'AVARIA'         ,
          tipclassinterno) AS DESCtipclassinterno,
   status                       ,
   decode (status,
           'A'   ,'ATIVO'  ,
           'I'   ,'INATIVO',
           status) DECstatus,
   dtaalteracao             ,
   usualteracao
from
   max_codgeraloper
ORDER BY
   codgeraloper</sql>
