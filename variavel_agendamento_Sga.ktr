  <step>
    <name>cliente</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Sga</connection>
    <sql>SELECT
    CASE
        WHEN EXISTS (
            SELECT 1
            FROM
                novosgaDB.tmp_agenda a
            LEFT JOIN
                novosgaDB.clientes b ON a.doc = b.documento
            WHERE
                b.documento IS NULL
                AND a.doc IS NOT NULL
        )
        THEN 'OK'
        ELSE 'NÃO'
    END AS resultado_sga_cliente;
</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
