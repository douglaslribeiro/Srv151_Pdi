  <step>
    <name>agenda</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Sga</connection>
    <sql>SELECT
    CASE
        WHEN EXISTS (
            SELECT 1
            FROM
               novosgaDB.tmp_agenda a
            JOIN
               novosgaDB.clientes b ON a.doc = b.documento
            JOIN
               novosgaDB.servicos c ON a.infoagenda = c.nome
            LEFT JOIN
               novosgaDB.agendamentos ag ON
                   ag.cliente_id = b.id AND
                   ag.unidade_id = 1 AND
                   ag.servico_id = c.id AND
                   ag.`data` = a.dta AND
                   ag.hora = a.hora AND
                   ag.situacao = a.status
            WHERE
               ag.cliente_id IS NULL
               AND a.status = 'agendado'
        )
        THEN 'OK'
        ELSE 'NÃO'
    END AS resultado_sga;
</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
