    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>with dados as(
select
    to_char((select cnpjcpf 
             from consincomonitor.tb_pessoa 
             where seqpessoa = (select seqpessoa 
                                from consincomonitor.tb_empresa 
                                where nroempresa = d.nroempresa)))||'/'||to_char(d.nrocheckout)||'/'||to_char(d.coo) as cnpj_chckt_coo,
    (select cnpjcpf 
     from consincomonitor.tb_pessoa 
     where seqpessoa = (select seqpessoa 
                        from consincomonitor.tb_empresa 
                        where nroempresa = d.nroempresa)) nroempresa,
    d.nrocheckout,
    d.seqdocto,
    d.dtamovimento,
    d.serie,
    d.coo,
    d.especie,
    d.dtahoremissao,
    d.sequsuario,
    a.nome as nomeusuario,
    e.cnpjcpf,
    d.nrosegmento,
    e.seqpessoa,
    e.status,
    e.codcliente,
    g.nroformapagto,
    sum(g.vlrtotal) as vlrtotal
from consincomonitor.tb_usuario a,
     consincomonitor.tb_grupousuario b,
     consincomonitor.tb_grupo c,
     consincomonitor.tb_docto d,
     consincomonitor.tb_doctocupom e,
     consincomonitor.tb_pessoa f,
     consincomonitor.tb_doctopagto g
where 
     a.sequsuario = b.sequsuario
     and b.seqgrupo = c.seqgrupo
     and a.sequsuario = d.sequsuario
     and d.nroempresa = e.nroempresa
     and d.nrocheckout = e.nrocheckout
     and d.seqdocto = e.seqdocto
     and e.seqpessoa = f.seqpessoa(+)
     and d.nroempresa = g.nroempresa
     and d.nrocheckout = g.nrocheckout
     and d.seqdocto = g.seqdocto
     and d.nroempresa in(select nroempresa from ge_empresa where matriz = 6)
     and c.nome like 'OPER%CAIXA%'
     and not exists(select cc.seqgrupo,cc.nome,aa.* 
                    from consincomonitor.tb_usuario aa,
                         consincomonitor.tb_grupousuario bb,
                         consincomonitor.tb_grupo cc
                    where 
                         aa.sequsuario = bb.sequsuario
                         and bb.seqgrupo = cc.seqgrupo
                         and a.sequsuario = aa.sequsuario
                         and cc.nome like 'IFOOD%')
     and not exists(select cc.seqgrupo,cc.nome,aa.* 
                    from consincomonitor.tb_usuario aa,
                         consincomonitor.tb_grupousuario bb,
                         consincomonitor.tb_grupo cc
                    where 
                         aa.sequsuario = bb.sequsuario
                         and bb.seqgrupo = cc.seqgrupo
                         and a.sequsuario = aa.sequsuario
                         and cc.nome like 'FISCAL%')
     and d.especie in('CF','CI')

     and d.dtamovimento between ? and ?

/*

--AND (EXTRACT(DAY   FROM(d.dtamovimento)) = EXTRACT(DAY   FROM(SYSDATE)))
AND (EXTRACT(MONTH FROM(d.dtamovimento)) = EXTRACT(MONTH FROM(SYSDATE)))
AND (EXTRACT(YEAR  FROM(d.dtamovimento)) = EXTRACT(YEAR  FROM(SYSDATE)))

*/



     and e.status = 'V'
     and (e.seqpessoa is not null or e.cnpjcpf is not null)
group by
    d.nroempresa,
    d.nrocheckout,
    d.seqdocto,
    d.dtamovimento,
    d.serie,
    d.coo,
    d.especie,
    d.dtahoremissao,
    d.sequsuario,
    a.nome,
    e.cnpjcpf,
    d.nrosegmento,
    e.seqpessoa,
    e.status,
    e.codcliente,
    g.nroformapagto)
select
    *
from(select
       rank()over(partition by dados.nroempresa
                  order by count(*) desc ) as "Rank",
       dados.nroempresa,
       dados.sequsuario,
       dados.nomeusuario,
       count(*) as total
     from dados
     group by
     dados.nroempresa,
     dados.sequsuario,
    dados.nomeusuario) k
--where k."Rank" = 1
WHERE k."Rank" between 1 and 1
order by
    total desc

</sql>
    <limit>0</limit>
    <lookup>DtIniFim</lookup>
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
