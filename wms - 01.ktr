  <step>
    <name>mlo_atividade</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>WITH WMS_01
AS (
	SELECT mlo_atividade.seqenderecomovto AS seqenderecomovto
		, mlo_atividade.nrocarga
		, mlo_atividade.nrocargareceb
		, mlo_atividade.seqatividade AS idatividade
		, mlo_tarefaprodut.codprodutivo AS idOperador
		, mlo_produtivo.produtivo AS nmOperador
		, mlo_atributofixo.descricao AS Funcao
		, mlo_tipatividade.atividade AS nmAtividadeTipo
		, mlo_linhaseparacao.desclinhasepar AS nmLinhaSepar
		, CASE 
			WHEN mlo_equipe.equipe = 'CDS'
				THEN 'CD Secos'
			WHEN mlo_equipe.equipe = 'CDF'
				THEN 'CD Frios'
			END AS Filial
		, CASE 
			WHEN mlo_tarefaprodut.codprodutivo IN (
					9999
					, 456
					, 500
					, 249
					, 250
					, 400
					, 898989
					, 251
					, 255
					, 152
					, 132
					, 278
					)
				THEN 'Sim'
			ELSE 'Não'
			END LIDERANCA
		, round(sum(mlo_atividade.peso)) AS Peso
		, sum(round(mlo_atividade.qtdvolume)) AS Volume
		, sum(mlo_atividade.qtditem) AS Item
		, trunc(mlo_tarefa.dtahorinitarefa) AS dtinitarefa
		, to_char(mlo_tarefa.dtahorinitarefa, 'hh24:mi:ss') AS hrinitarefa
		, CASE 
			WHEN EXTRACT(MONTH FROM ADD_MONTHS(TRUNC(SYSDATE), - 1)) &lt;&gt; EXTRACT(MONTH FROM TRUNC(DTAHORINITAREFA))
				THEN 'Mês Atual'
			ELSE 'Mês Anterior'
			END AS MesAtualAnterior
		, CASE 
			WHEN TRUNC(SYSDATE) = TRUNC(mlo_tarefa.dtahorinitarefa)
				THEN 'Data Atual'
			ELSE 'Data Anterior'
			END AS DataAtualAnterior
		, trunc(mlo_tarefa.dtahorfimtarefa) AS dtfimtarefa
		, to_char(mlo_tarefa.dtahorfimtarefa, 'hh24:mi:ss') AS hrfimtarefa
		, trunc(24 * (mlo_tarefa.dtahorfimtarefa - mlo_tarefa.dtahorinitarefa)) AS horas
		, abs(trunc((MOD(MOD(mlo_tarefa.dtahorfimtarefa - mlo_tarefa.dtahorinitarefa, 1) * 24, 1) * 60))) AS minutos
		, abs(trunc((MOD((MOD(MOD(mlo_tarefa.dtahorfimtarefa - mlo_tarefa.dtahorinitarefa, 1) * 24, 1) * 60), 1) * 60))) AS segundos
	FROM mlo_atividade
	INNER JOIN mlo_tarefa ON mlo_atividade.seqtarefa = mlo_tarefa.seqtarefa AND mlo_atividade.mesano = mlo_tarefa.mesano AND mlo_atividade.nroempresa = mlo_tarefa.nroempresa
	INNER JOIN mlo_tarefaprodut ON mlo_atividade.seqtarefa = mlo_tarefaprodut.seqtarefa AND mlo_atividade.mesano = mlo_tarefaprodut.mesano AND mlo_atividade.nroempresa = mlo_tarefaprodut.nroempresa
	INNER JOIN mlo_produtivo ON mlo_tarefaprodut.codprodutivo = mlo_produtivo.codprodutivo AND mlo_tarefaprodut.nroempresa = mlo_produtivo.nroempresa
	INNER JOIN mlo_atributofixo ON mlo_produtivo.tipfuncao = mlo_atributofixo.lista
	INNER JOIN mlo_equipe ON mlo_produtivo.codequipe = mlo_equipe.codequipe AND mlo_produtivo.nroempresa = mlo_equipe.nroempresa
	INNER JOIN mlo_tipatividade ON mlo_atividade.codtipatividade = mlo_tipatividade.codtipatividade AND mlo_atividade.nroempresa = mlo_tipatividade.nroempresa
	LEFT JOIN mlo_enderecoatividade ON mlo_atividade.seqatividade = mlo_enderecoatividade.seqatividade AND mlo_atividade.statusatividade = mlo_enderecoatividade.statusatividade
	LEFT JOIN mlo_linhaseparperm ON mlo_enderecoatividade.seqendereco = mlo_linhaseparperm.seqendereco AND mlo_atividade.nroempresa = mlo_linhaseparperm.nroempresa
	LEFT JOIN mlo_linhaseparacao ON mlo_linhaseparperm.codlinhasepar = mlo_linhaseparacao.codlinhasepar AND mlo_linhaseparperm.nroempresa = mlo_linhaseparacao.nroempresa
	WHERE mlo_atividade.nroempresa = 6 AND mlo_atributofixo.tipatributofixo = 'FUNCAO' AND mlo_atividade.indexclusao &lt;&gt; 'S' AND mlo_tipatividade.codtipatividade NOT IN ('IN') AND mlo_equipe.equipe = 'CDS'
		--AND TRUNC(DTAHORINITAREFA) >= '1-' || EXTRACT(MONTH FROM ADD_MONTHS(TRUNC(SYSDATE), - 1)) || '-' || EXTRACT(YEAR FROM ADD_MONTHS(TRUNC(SYSDATE), - 1))
		--AND TRUNC(DTAHORINITAREFA) >= TO_DATE('01-' || EXTRACT(MONTH FROM ADD_MONTHS(TRUNC(SYSDATE), -1)) || '-' || EXTRACT(YEAR FROM ADD_MONTHS(TRUNC(SYSDATE), -1)), 'DD-MM-YYYY')
		AND TRUNC(DTAHORINITAREFA) >= TRUNC(SYSDATE - ?)
	GROUP BY 
	      mlo_atividade.seqenderecomovto
		, mlo_atividade.nrocarga
		, mlo_atividade.nrocargareceb
		, mlo_atividade.seqatividade
		, mlo_tarefaprodut.codprodutivo
		, mlo_produtivo.produtivo
		, mlo_atributofixo.descricao
		, mlo_tipatividade.atividade
		, mlo_linhaseparacao.desclinhasepar
		, mlo_equipe.equipe
		, mlo_tarefa.dtahorinitarefa
		, mlo_tarefa.dtahorfimtarefa
	)
	, WMS_02
AS (
	SELECT B.SEQENDERECO
		, A.*
	FROM WMS_01 A
	LEFT JOIN mlo_enderecomovto B ON A.seqenderecomovto = B.seqenderecomovto
	ORDER BY DTINITAREFA DESC
	)
SELECT 
      A.*
	, B.NROEMPRESA
	, B.CODDEPOSITO
	, B.CODRUA
	, B.NROPREDIO
	, B.NROAPARTAMENTO
	, B.NROSALA
    , B.especieendereco
    , B.indterreoaereo
    , B.tipespecie
FROM WMS_02 A
LEFT JOIN mlo_endereco B ON A.SEQENDERECO = B.SEQENDERECO</sql>
    <limit>0</limit>
    <lookup>Qtd. Dias</lookup>
