    <sql>SELECT
  IDPRODUTO
, DESCRICAO
, DEPARTAMENTO
, SETOR
, GRUPO
, FAMILIA
, COMPRADOR
, SITUACAO
, SITUACAOCOMPRA
, DATAATUALIZACAO
, SEQCOMPRADOR
, SEQFAMILIA
, TIPOAVARIA
, SEQFORNECEDOR
