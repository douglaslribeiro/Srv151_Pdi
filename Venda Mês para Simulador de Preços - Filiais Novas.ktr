, FORNECEDOR
, SEQPRODUTOBASE
, DTAHORINCLUSAO
, DTAHORALTERACAO
, DATA_ATUALIZACAO
, NOME_TRANSFORMACAO

FROM dbo.dim_produtos
</sql>
