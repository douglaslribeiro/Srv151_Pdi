  <notepads>
    <notepad>
      <note>22.04.25
SELECT PR1.SEQPROMOCAO
	,--jefferson
	GP1.SEQGRUPOPROMOC
	,to_char(DTAHORLANCTO, 'hh24') AS HoraVenda
	,V.DTAVDA AS dtMovimento
	,V.NROEMPRESA
	,V.NROSEGMENTO
	,A.SEQPRODUTO
	,K.QTDEMBALAGEM AS QTDEMBALAGEM
	,sum(round((V.QTDITEM - V.QTDDEVOLITEM) / K.QTDEMBALAGEM, 6)) AS QUANTIDADE
	,count(DISTINCT V.ROWIDDOCTO) AS NRODOCTOS
	,count(DISTINCT V.SEQPESSOA) AS NROCLIENTES
	,count(DISTINCT V.SEQPRODUTO) AS NROITENS
	,--jefferson
	sum(((round(V.VLRITEM, 2)) - (round(V.VLRDEVOLITEM, 2) - (0))) + nvl(VLREMBDESCRESSARCST, 0) - nvl(VLREMBDESCRESSARCSTDEVOL, 0)) AS VLRVENDALIQ
	,SUM(coalesce(V.VLRVENDAPROMOC - CASE 
				WHEN V.VLRVENDAPROMOC > 0
					THEN nvl(VLRDESCITEM, 0)
				ELSE 0
				END, (decode(nvl(consinco.fmrl_seqpromocProd(A.SEQPRODUTO, Y.NROEMPRESA, NVL(V.DTANFREF, Y.DTAENTRADASAIDA), V.NROSEGMENTO, NULL), 0), 0, 0, (round(V.VLRITEM, 2)) - (round(V.VLRDEVOLITEM, 2) - (0)))))) AS VLRVENDAPROMOC
	,round(sum(consinco.fC5_AbcDistribLucratividade('L', 'L', 'N', V.VLRITEM, 'N', V.VLRICMSST, V.VLRFCPST, V.VLRICMSSTEMPORIG, E.UF, V.UFPESSOA, 'N', 0, 'N', V.VLRIPIITEM, V.VLRIPIDEVOLITEM, 'N', V.VLRDESCFORANF, Y.CMDIAVLRNF - 0, Y.CMDIAIPI, nvl(Y.CMDIACREDPIS, 0), nvl(Y.CMDIACREDCOFINS, 0), Y.CMDIAICMSST, Y.CMDIADESPNF, Y.CMDIADESPFORANF, Y.CMDIADCTOFORANF, 'S', a.propqtdprodutobase, V.QTDITEM, V.VLREMBDESCRESSARCST, V.ACMCOMPRAVENDA, V.PISITEM, V.COFINSITEM, decode(V.TIPCGO, 'S', Y.QTDVDA, nvl(Y.QTDDEVOL, Y.QTDVDA)), (decode(V.TIPCGO, 'S', Y.VLRIMPOSTOVDA - nvl(Y.VLRIPIVDA, 0), nvl(Y.VLRIMPOSTODEVOL - nvl(V.VLRIPIDEVOLITEM, 0), Y.VLRIMPOSTOVDA - nvl(Y.VLRIPIVDA, 0)))), 'N', V.VLRDESPOPERACIONALITEM, Y.VLRDESPESAVDA, 'N', nvl(Y.VLRVERBAVDAACR, 0), Y.QTDVERBAVDA, Y.VLRVERBAVDA - nvl(Y.VLRVERBAVDAINDEVIDA, 0), 'N', NVL(V.VLRTOTCOMISSAOITEM, 0), V.VLRDEVOLITEM, VLRDEVOLICMSST, V.DVLRFCPST, V.QTDDEVOLITEM, V.PISDEVOLITEM, V.COFINSDEVOLITEM, V.VLRDESPOPERACIONALITEMDEVOL, V.VLRTOTCOMISSAOITEMDEVOL, E.PERIRLUCRAT, E.PERCSLLLUCRAT, Y.
				CMDIACREDICMS, V.ICMSITEM, V.VLRFCPICMS, V.PERCPMF, V.PEROUTROIMPOSTO, V.ICMSDEVOLITEM, V.DVLRFCPICMS, CASE 
					WHEN ('S') = 'N'
						THEN (nvl(y.cmdiavlrdescpistransf, 0) + nvl(y.cmdiavlrdesccofinstransf, 0) + nvl(y.cmdiavlrdescicmstransf, 0) + nvl(y.cmdiavlrdescipitransf, 0) + nvl(y.cmdiavlrdesclucrotransf, 0) + nvl(y.cmdiavlrdescverbatransf, 0))
					ELSE 0
					END,
				--/*
				CASE 
					WHEN DV.UTILACRESCCUSTPRODRELAC = 'S'
						AND nvl(A.SEQPRODUTOBASE, A.SEQPRODUTOBASEANTIGO) IS NOT NULL
						THEN coalesce(PR.PERCACRESCCUSTORELACVIG, nvl(consinco.F_RETACRESCCUSTORELACABC(V.SEQPRODUTO, V.DTAVDA), 1))
					ELSE 1
					END, 'N', 0, 0, 'S', V.VLRDESCMEDALHA, 'S', V.VLRDESCFORNEC, V.VLRDESCFORNECDEVOL, 'N', V.VLRFRETEITEMRATEIO, V.VLRFRETEITEMRATEIODEV, 'S', V.VLRICMSSTEMBUTPROD, V.VLRICMSSTEMBUTPRODDEV, V.VLREMBDESCRESSARCSTDEVOL, CASE 
					WHEN 'S' = 'S'
						THEN nvl(V.VLRDESCACORDOVERBAPDV, 0)
					ELSE 0
					END, nvl(Y.CMDIACREDIPI, 0), NVL(V.VLRITEMRATEIOCTE, 0), 'N', 'C', V.VLRIPIPRECOVDA, V.VLRIPIPRECODEVOL, V.VLRDESCMEDALHADEVOL)), 2) AS VLRLUCRO_01
	,
	--*/
	round(sum(fC5_AbcDistribLucratividade('L', 'L', 'N', V.VLRITEM, 'N', V.VLRICMSST, V.VLRFCPST, V.VLRICMSSTEMPORIG, E.UF, V.UFPESSOA, 'N', 0, 'N', V.VLRIPIITEM, V.VLRIPIDEVOLITEM, 'N', V.VLRDESCFORANF, Y.CMDIAVLRNF - 0, Y.CMDIAIPI, nvl(Y.CMDIACREDPIS, 0), nvl(Y.CMDIACREDCOFINS, 0), Y.CMDIAICMSST, Y.CMDIADESPNF, Y.CMDIADESPFORANF, Y.CMDIADCTOFORANF, 'S', a.propqtdprodutobase, V.QTDITEM, V.VLREMBDESCRESSARCST, V.ACMCOMPRAVENDA, V.PISITEM, V.COFINSITEM, decode(V.TIPCGO, 'S', Y.QTDVDA, nvl(Y.QTDDEVOL, Y.QTDVDA)), (decode(V.TIPCGO, 'S', Y.VLRIMPOSTOVDA - nvl(Y.VLRIPIVDA, 0), nvl(((Y.VLRIMPOSTODEVOL / decode(nvl(Y.QTDDEVOL, 0), 0, 1, Y.QTDDEVOL)) * V.QTDDEVOLITEM) - nvl(V.VLRIPIDEVOLITEM, 0), Y.VLRIMPOSTOVDA - nvl(Y.VLRIPIVDA, 0)))), 'N', V.VLRDESPOPERACIONALITEM, Y.VLRDESPESAVDA, 'N', nvl(Y.VLRVERBAVDAACR, 0), V.QTDVERBAVDA, V.VLRVERBAVDA, 'N', NVL(V.VLRTOTCOMISSAOITEM, 0), V.VLRDEVOLITEM, VLRDEVOLICMSST, V.DVLRFCPST, V.QTDDEVOLITEM, V.PISDEVOLITEM, V.COFINSDEVOLITEM, V.VLRDESPOPERACIONALITEMDEVOL, V.VLRTOTCOMISSAOITEMDEVOL, E.PERIRLUCRAT, E.PERCSLLLUCRAT, Y.CMDIACREDICMS, V.ICMSITEM, V.VLRFCPICMS, V.PERCPMF, V.PEROUTROIMPOSTO, V.ICMSDEVOLITEM, V.DVLRFCPICMS, CASE WHEN('N') = 'N'  THEN(nvl(y.cmdiavlrdescpistransf, 0) + nvl(y.cmdiavlrdesccofinstransf, 0) + nvl(y.cmdiavlrdescicmstransf, 0) + nvl(y.cmdiavlrdescipitransf, 0) + nvl(y.cmdiavlrdesclucrotransf, 0) + nvl(y.cmdiavlrdescverbatransf, 0))  ELSE 0  END
					,CASE  WHEN DV.UTILACRESCCUSTPRODRELAC = 'S'  AND nvl(A.SEQPRODUTOBASE, A.SEQPRODUTOBASEANTIGO) IS NOT NULL  THEN coalesce(PR.PERCACRESCCUSTORELACVIG, nvl(F_RETACRESCCUSTORELACABC(V.SEQPRODUTO, V.DTAVDA), 1))  ELSE 1  END
						,'N'
						,0
						,0
						,'S'
						,V.VLRDESCMEDALHA
						,'S'
						,V.VLRDESCFORNEC
						,V.VLRDESCFORNECDEVOL
						,'N'
						,V.VLRFRETEITEMRATEIO
						,V.VLRFRETEITEMRATEIODEV
						,'S'
						,V.VLRICMSSTEMBUTPROD
						,V.VLRICMSSTEMBUTPRODDEV
						,V.VLREMBDESCRESSARCSTDEVOL
						,CASE WHEN 'N' = 'S'  THEN nvl(V.VLRDESCACORDOVERBAPDV, 0) ELSE 0  END
							,nvl(Y.CMDIACREDIPI, 0)
							,NVL(V.VLRITEMRATEIOCTE, 0)
							,'N'
							,'I'
							,V.VLRIPIPRECOVDA
							,V.VLRIPIPRECODEVOL
							,V.VLRDESCMEDALHADEVOL ) )
							,2 ) AS VLRLUCRO
							,sum(V.ICMSITEM - V.ICMSDEVOLITEM) AS VLRICMS
							,sum(V.VLRFCPICMS - V.DVLRFCPICMS) AS VLRFCP
							,sum((V.PISITEM - V.PISDEVOLITEM)) AS VLRPIS
							,sum((V.COFINSITEM - V.COFINSDEVOLITEM)) AS VLRCOFINS
							,sum((decode(Y.QTDVERBAVDA, 0, 0, (Y.VLRVERBAVDA - nvl(Y.VLRverbaVDAindevida, 0)) * nvl(a.propqtdprodutobase, 1) / Y.QTDVDA)) * (V.QTDITEM - 0)) AS VLRVERBAVDA
							,sum((V.VLRVERBACOMPRA - V.VLRVERBACOMPRADEV) + (V.VLRVERBABONIFINCID - V.VLRVERBABONIFINCIDDEV) + (V.VLRVERBABONIFSEMINCID - V.VLRVERBABONIFSEMINCIDDEV)) AS VLRVERBASELLIN
							,sum(((V.VLRVERBAPDV - V.VLRVERBAPDVDEVOL) * DECODE('S', 'N', 1, NVL(a.propqtdprodutobase, 1)))) AS VLRVERBAPDV
							,sum(((round(V.VLRITEM, 2)) - (round(V.VLRDEVOLITEM, 2) - (0))) + NVL(V.VLRDESCFORNEC, 0) + NVL(V.VLRDESCMEDALHA, 0) + nvl(VLREMBDESCRESSARCST, 0) - nvl(VLREMBDESCRESSARCSTDEVOL, 0)) AS VLRTOTLIQMARGEM
							,round(SUM(FC5_ABCDISTRIBCUSTOBRUTO('L', 'N', Y.CMDIAVLRNF - CASE 
											WHEN 'N' = 'S'
												THEN fc5_divide(fc5_divide(V.VLRDESCACORDOVERBAPDV, (V.QTDITEM - V.QTDDEVOLITEM)), V.QTDEMBALITEM)
											ELSE 0
											END, Y.CMDIAIPI, Y.CMDIAICMSST, Y.CMDIADESPNF, Y.CMDIADESPFORANF, Y.CMDIADCTOFORANF - nvl(Y.CMULTIMPOSTOPRESUM, 0), Y.CMDIACREDICMS, 'S', a.propqtdprodutobase, decode(V.ACMCOMPRAVENDA, 'N', 0, Y.QTDVERBAVDA), Y.VLRVERBAVDA, Y.QTDVDA, V.QTDITEM, V.QTDDEVOLITEM, CASE 
											WHEN ('N') = 'N'
												THEN (nvl(y.cmdiavlrdescpistransf, 0) + nvl(y.cmdiavlrdesccofinstransf, 0) + nvl(y.cmdiavlrdescicmstransf, 0) + nvl(y.cmdiavlrdescipitransf, 0) + nvl(y.cmdiavlrdesclucrotransf, 0) + nvl(y.cmdiavlrdescverbatransf, 0) + nvl(y.cmdiavlrdescdiferencatransf, 0))
											ELSE 0
											END, decode(V.ACMCOMPRAVENDA, 'N', 0, nvl(Y.VLRVERBAVDAACR, 0)), 'N', (
											CASE 
												WHEN DV.UTILACRESCCUSTPRODRELAC = 'S'
													AND NVL(A.SEQPRODUTOBASE, A.SEQPRODUTOBASEANTIGO) IS NOT NULL
													THEN COALESCE(PR.PERCACRESCCUSTORELACVIG, NVL(F_RETACRESCCUSTORELACABC(V.SEQPRODUTO, V.DTAVDA), 1))
												ELSE 1
												END
											))), 2) AS VLRCTOBRUTO --jefferson
							FROM MRL_CUSTODIA Y
							,CONSINCO.MAXV_ABCDISTRIBBASE V
							,MAP_PRODUTO A
							,MAP_PRODUTO PB
							,MAP_FAMDIVISAO D
							,MAP_FAMEMBALAGEM K
							,MAX_EMPRESA E
							,MAX_DIVISAO DV
							,MAP_PRODACRESCCUSTORELAC PR
							,MAXV_ABCPROMOCAO_DISTINCT PR1
							,--jefferson
							MRL_GRUPOPROMOCAO GP1 --jefferson
							WHERE D.SEQFAMILIA = A.SEQFAMILIA
							AND PR1.SEQPRODUTO(+) = V.SEQPRODUTO --jefferson
							AND PR1.NROEMPRESA(+) = V.NROEMPRESA --jefferson
							AND PR1.NROSEGMENTO(+) = V.NROSEGMENTO --jefferson
							AND PR1.SEQPROMOCAO(+) = V.SEQPROMOCAO --jefferson
							AND PR1.SEQGRUPOPROMOC = GP1.SEQGRUPOPROMOC(+) --jefferson
							AND PR1.DTAGERACAO(+) IS NOT NULL --jefferson
							AND PR1.QTDEMBALAGEM(+) = V.QTDEMBALITEM --jefferson
							AND D.NRODIVISAO = V.NRODIVISAO
							AND V.SEQPRODUTO = A.SEQPRODUTO
							AND V.SEQPRODUTOCUSTO = PB.SEQPRODUTO
							--and V.NROSEGMENTO in ( 2,5,3,4,10,1 )
							AND V.NRODIVISAO = D.NRODIVISAO
							AND E.NROEMPRESA = V.NROEMPRESA
							AND E.NRODIVISAO = DV.NRODIVISAO
							AND V.SEQPRODUTO = PR.SEQPRODUTO(+)
							AND V.DTAVDA = PR.DTAMOVIMENTACAO(+)
							AND Y.NROEMPRESA = nvl(E.NROEMPCUSTOABC, E.NROEMPRESA)
							AND Y.DTAENTRADASAIDA = V.DTAVDA
							AND K.SEQFAMILIA = A.SEQFAMILIA
							AND K.QTDEMBALAGEM = 1
							AND Y.SEQPRODUTO = PB.SEQPRODUTO
							AND DECODE(V.TIPTABELA, 'S', V.CGOACMCOMPRAVENDA, V.ACMCOMPRAVENDA) IN (
								'S'
								,'I'
								)
							--AND V.codgeraloper IN (202,810,800,918,924,329,322,811,344,950,345,963)
							--AND V.NROEMPRESA = 20
							--and V.DTAVDA BETWEEN Current_Date - 5 AND Current_Date - 4
							-- AND V.DTAVDA BETWEEN '01-03-2025' AND '01-03-2025'
							and V.DTAVDA > ?
							GROUP BY A.SEQPRODUTO
							,V.NROSEGMENTO
							,V.NROEMPRESA
							,A.DESCCOMPLETA
							,A.SEQPRODUTO
							,A.DESCCOMPLETA
							,A.DESCCOMPLETA
							,to_number(NULL)
							,K.QTDEMBALAGEM
							,K.EMBALAGEM || ' ' || K.QTDEMBALAGEM
							,K.LITROS
							,V.DTAVDA
							,to_char(DTAHORLANCTO, 'hh24')
							,NVL(GP1.DESCRICAO, '** Sem Grupo de Promoções **')
							,--jefferson
							PR1.PROMOCAO
							,--jefferson
							PR1.SEQPROMOCAO
							,--jeferson
							GP1.SEQGRUPOPROMOC
			


/* 22 04 25
select
  PR1.SEQPROMOCAO,--jefferson
  GP1.SEQGRUPOPROMOC,
  to_char(DTAHORLANCTO,'hh24') as HoraVenda,
  V.DTAVDA as dtMovimento,
  V.NROEMPRESA,
  V.NROSEGMENTO,
  A.SEQPRODUTO,
  K.QTDEMBALAGEM as QTDEMBALAGEM,
  sum( round(( V.QTDITEM - V.QTDDEVOLITEM ) / K.QTDEMBALAGEM , 6) ) as QUANTIDADE,
  count( distinct V.ROWIDDOCTO ) as NRODOCTOS,
  count( distinct V.SEQPESSOA ) as NROCLIENTES,
  sum( ( ( round( V.VLRITEM, 2 ) ) - ( round( V.VLRDEVOLITEM, 2 ) - ( 0 ) ) ) + nvl( VLREMBDESCRESSARCST, 0 ) - nvl( VLREMBDESCRESSARCSTDEVOL, 0 ) ) as VLRVENDALIQ,
  SUM( coalesce(V.VLRVENDAPROMOC -
  case
  when
    V.VLRVENDAPROMOC > 0
  then
    nvl(VLRDESCITEM,0)
  else
    0
  end, (decode( nvl( consinco.fmrl_seqpromocProd( A.SEQPRODUTO, Y.NROEMPRESA, NVL(V.DTANFREF,Y.DTAENTRADASAIDA), V.NROSEGMENTO, null ), 0 ),
                0, 0,
                ( round( V.VLRITEM, 2 ) ) - ( round( V.VLRDEVOLITEM, 2 ) - ( 0 ) ) ))) ) as VLRVENDAPROMOC,
  round(sum( consinco.fC5_AbcDistribLucratividade( 'L', 'L', 'N', V.VLRITEM , 'N', V.VLRICMSST, V.VLRFCPST, V.VLRICMSSTEMPORIG, E.UF, V.UFPESSOA, 'N', 0, 'N', V.VLRIPIITEM, V.VLRIPIDEVOLITEM, 'N', V.VLRDESCFORANF, Y.CMDIAVLRNF - 0 , Y.CMDIAIPI, nvl( Y.CMDIACREDPIS, 0 ), nvl( Y.CMDIACREDCOFINS, 0 ), Y.CMDIAICMSST, Y.CMDIADESPNF, Y.CMDIADESPFORANF, Y.CMDIADCTOFORANF, 'S', a.propqtdprodutobase, V.QTDITEM, V.VLREMBDESCRESSARCST, V.ACMCOMPRAVENDA, V.PISITEM, V.COFINSITEM, decode( V.TIPCGO,
                                                                                                                                                                                                                                                                                                                                                                                                                'S', Y.QTDVDA,
                                                                                                                                                                                                                                                                                                                                                                                                                nvl( Y.QTDDEVOL, Y.QTDVDA ) ), ( decode( V.TIPCGO,
                                                                                                                                                                                                                                                                                                                                                                                                                'S', Y.VLRIMPOSTOVDA - nvl( Y.VLRIPIVDA, 0 ),
                                                                                                                                                                                                                                                                                                                                                                                                                nvl( Y.VLRIMPOSTODEVOL - nvl( V.VLRIPIDEVOLITEM, 0 ), Y.VLRIMPOSTOVDA - nvl( Y.VLRIPIVDA, 0 ) ) ) ) , 'N', V.VLRDESPOPERACIONALITEM, Y.VLRDESPESAVDA, 'N', nvl( Y.VLRVERBAVDAACR, 0 ), Y.QTDVERBAVDA, Y.VLRVERBAVDA - nvl( Y.VLRVERBAVDAINDEVIDA, 0 ), 'N', NVL(V.VLRTOTCOMISSAOITEM, 0), V.VLRDEVOLITEM, VLRDEVOLICMSST, V.DVLRFCPST, V.QTDDEVOLITEM, V.PISDEVOLITEM, V.COFINSDEVOLITEM, V.VLRDESPOPERACIONALITEMDEVOL, V.VLRTOTCOMISSAOITEMDEVOL, E.PERIRLUCRAT, E.PERCSLLLUCRAT, Y.CMDIACREDICMS, V.ICMSITEM, V.VLRFCPICMS, V.PERCPMF, V.PEROUTROIMPOSTO, V.ICMSDEVOLITEM, V.DVLRFCPICMS,
  case
  when
    ( 'S' ) = 'N'
  then
    (nvl(y.cmdiavlrdescpistransf,0) + nvl(y.cmdiavlrdesccofinstransf,0) + nvl(y.cmdiavlrdescicmstransf,0) + nvl(y.cmdiavlrdescipitransf,0) + nvl(y.cmdiavlrdesclucrotransf,0) + nvl(y.cmdiavlrdescverbatransf,0) )
  else
    0
  end,
  --/*
  case
  when
    DV.UTILACRESCCUSTPRODRELAC = 'S'
    and nvl( A.SEQPRODUTOBASE, A.SEQPRODUTOBASEANTIGO ) is not null
  then
    coalesce( PR.PERCACRESCCUSTORELACVIG, nvl( consinco.F_RETACRESCCUSTORELACABC( V.SEQPRODUTO, V.DTAVDA ), 1 ) )
  else
    1
  end, 'N', 0, 0, 'S', V.VLRDESCMEDALHA, 'S', V.VLRDESCFORNEC, V.VLRDESCFORNECDEVOL, 'N', V.VLRFRETEITEMRATEIO, V.VLRFRETEITEMRATEIODEV, 'S', V.VLRICMSSTEMBUTPROD, V.VLRICMSSTEMBUTPRODDEV, V.VLREMBDESCRESSARCSTDEVOL,
  case
  when
    'S' = 'S'
  then
    nvl( V.VLRDESCACORDOVERBAPDV, 0 )
  else
    0
  end, nvl( Y.CMDIACREDIPI, 0 ), NVL(V.VLRITEMRATEIOCTE,0), 'N', 'C', V.VLRIPIPRECOVDA, V.VLRIPIPRECODEVOL, V.VLRDESCMEDALHADEVOL )), 2 ) as VLRLUCRO_01,
  --*/
 round(sum(fC5_AbcDistribLucratividade('L', 'L', 'N', V.VLRITEM, 'N', V.VLRICMSST, V.VLRFCPST, V.VLRICMSSTEMPORIG, E.UF, V.UFPESSOA, 'N', 0, 'N', V.VLRIPIITEM, V.VLRIPIDEVOLITEM, 'N', V.VLRDESCFORANF, Y.CMDIAVLRNF - 0, Y.CMDIAIPI, nvl(Y.CMDIACREDPIS, 0), nvl(Y.CMDIACREDCOFINS, 0), Y.CMDIAICMSST, Y.CMDIADESPNF, Y.CMDIADESPFORANF, Y.CMDIADCTOFORANF, 'S', a.propqtdprodutobase, V.QTDITEM, V.VLREMBDESCRESSARCST, V.ACMCOMPRAVENDA, V.PISITEM, V.COFINSITEM, decode(V.TIPCGO, 'S', Y.QTDVDA, nvl(Y.QTDDEVOL, Y.QTDVDA)), (decode(V.TIPCGO, 'S', Y.VLRIMPOSTOVDA - nvl(Y.VLRIPIVDA, 0), nvl(((Y.VLRIMPOSTODEVOL / decode(nvl(Y.QTDDEVOL, 0), 0, 1, Y.QTDDEVOL)) * V.QTDDEVOLITEM) - nvl(V.VLRIPIDEVOLITEM, 0), Y.VLRIMPOSTOVDA - nvl(Y.VLRIPIVDA, 0)))), 'N', V.VLRDESPOPERACIONALITEM, Y.VLRDESPESAVDA, 'N', nvl(Y.VLRVERBAVDAACR, 0), V.QTDVERBAVDA, V.VLRVERBAVDA, 'N', NVL(V.VLRTOTCOMISSAOITEM, 0), V.VLRDEVOLITEM, VLRDEVOLICMSST, V.DVLRFCPST, V.QTDDEVOLITEM, V.PISDEVOLITEM, V.COFINSDEVOLITEM, V.
				VLRDESPOPERACIONALITEMDEVOL, V.VLRTOTCOMISSAOITEMDEVOL, E.PERIRLUCRAT, E.PERCSLLLUCRAT, Y.CMDIACREDICMS, V.ICMSITEM, V.VLRFCPICMS, V.PERCPMF, V.PEROUTROIMPOSTO, V.ICMSDEVOLITEM, V.DVLRFCPICMS, CASE 
					WHEN ('N') = 'N'
						THEN (nvl(y.cmdiavlrdescpistransf, 0) + nvl(y.cmdiavlrdesccofinstransf, 0) + nvl(y.cmdiavlrdescicmstransf, 0) + nvl(y.cmdiavlrdescipitransf, 0) + nvl(y.cmdiavlrdesclucrotransf, 0) + nvl(y.cmdiavlrdescverbatransf, 0))
					ELSE 0
					END, CASE 
					WHEN DV.UTILACRESCCUSTPRODRELAC = 'S'
						AND nvl(A.SEQPRODUTOBASE, A.SEQPRODUTOBASEANTIGO) IS NOT NULL
						THEN coalesce(PR.PERCACRESCCUSTORELACVIG, nvl(F_RETACRESCCUSTORELACABC(V.SEQPRODUTO, V.DTAVDA), 1))
					ELSE 1
					END, 'N', 0, 0, 'S', V.VLRDESCMEDALHA, 'S', V.VLRDESCFORNEC, V.VLRDESCFORNECDEVOL, 'N', V.VLRFRETEITEMRATEIO, V.VLRFRETEITEMRATEIODEV, 'S', V.VLRICMSSTEMBUTPROD, V.VLRICMSSTEMBUTPRODDEV, V.VLREMBDESCRESSARCSTDEVOL, CASE 
					WHEN 'N' = 'S'
						THEN nvl(V.VLRDESCACORDOVERBAPDV, 0)
					ELSE 0
					END, nvl(Y.CMDIACREDIPI, 0), NVL(V.VLRITEMRATEIOCTE, 0), 'N', 'I', V.VLRIPIPRECOVDA, V.VLRIPIPRECODEVOL, V.VLRDESCMEDALHADEVOL)), 2) AS VLRLUCRO,  
  sum( V.ICMSITEM - V.ICMSDEVOLITEM ) as VLRICMS,
  sum( V.VLRFCPICMS - V.DVLRFCPICMS ) as VLRFCP,
  sum( ( V.PISITEM - V.PISDEVOLITEM ) ) as VLRPIS,
  sum( ( V.COFINSITEM - V.COFINSDEVOLITEM ) ) as VLRCOFINS,
  sum( ( decode( Y.QTDVERBAVDA,
                 0, 0,
                 ( Y.VLRVERBAVDA - nvl( Y.VLRverbaVDAindevida, 0 ) ) * nvl( a.propqtdprodutobase, 1 ) / Y.QTDVDA ) ) * ( V.QTDITEM - 0 ) ) as VLRVERBAVDA,
  sum( ( V.VLRVERBACOMPRA - V.VLRVERBACOMPRADEV ) + ( V.VLRVERBABONIFINCID - V.VLRVERBABONIFINCIDDEV ) + ( V.VLRVERBABONIFSEMINCID - V.VLRVERBABONIFSEMINCIDDEV ) ) as VLRVERBASELLIN,
  sum( ( ( V.VLRVERBAPDV - V.VLRVERBAPDVDEVOL ) * DECODE('S',
                                                         'N',1,
                                                         NVL( a.propqtdprodutobase, 1) ) ) ) as VLRVERBAPDV,
  sum( ( ( round( V.VLRITEM, 2 ) ) - ( round( V.VLRDEVOLITEM, 2 ) - ( 0 ) ) ) + NVL(V.VLRDESCFORNEC,0) + NVL(V.VLRDESCMEDALHA,0) + nvl( VLREMBDESCRESSARCST, 0 ) - nvl( VLREMBDESCRESSARCSTDEVOL, 0 ) ) as VLRTOTLIQMARGEM
from
  MRL_CUSTODIA Y,
  CONSINCO.MAXV_ABCDISTRIBBASE V,
  MAP_PRODUTO A,
  MAP_PRODUTO PB,
  MAP_FAMDIVISAO D,
  MAP_FAMEMBALAGEM K,
  MAX_EMPRESA E,
  MAX_DIVISAO DV,
  MAP_PRODACRESCCUSTORELAC PR,
  MAXV_ABCPROMOCAO_DISTINCT PR1, --jefferson
  MRL_GRUPOPROMOCAO GP1 --jefferson
where
  D.SEQFAMILIA = A.SEQFAMILIA
AND PR1.SEQPRODUTO(+) = V.SEQPRODUTO --jefferson
AND PR1.NROEMPRESA(+) = V.NROEMPRESA --jefferson
AND PR1.NROSEGMENTO(+) = V.NROSEGMENTO --jefferson
AND PR1.SEQPROMOCAO(+) = V.SEQPROMOCAO --jefferson
AND PR1.SEQGRUPOPROMOC = GP1.SEQGRUPOPROMOC(+)--jefferson
AND PR1.DTAGERACAO(+) IS NOT NULL --jefferson
AND PR1.QTDEMBALAGEM(+) = V.QTDEMBALITEM --jefferson
and D.NRODIVISAO = V.NRODIVISAO
and V.SEQPRODUTO = A.SEQPRODUTO
and V.SEQPRODUTOCUSTO = PB.SEQPRODUTO
  --and V.NROSEGMENTO in ( 2,5,3,4,10,1 )
and V.NRODIVISAO = D.NRODIVISAO
and E.NROEMPRESA = V.NROEMPRESA
and E.NRODIVISAO = DV.NRODIVISAO
AND V.SEQPRODUTO = PR.SEQPRODUTO(+)
AND V.DTAVDA = PR.DTAMOVIMENTACAO(+)
and Y.NROEMPRESA = nvl( E.NROEMPCUSTOABC, E.NROEMPRESA )
and Y.DTAENTRADASAIDA = V.DTAVDA
and K.SEQFAMILIA = A.SEQFAMILIA
and K.QTDEMBALAGEM = 1
and Y.SEQPRODUTO = PB.SEQPRODUTO
and DECODE(V.TIPTABELA,
           'S', V.CGOACMCOMPRAVENDA,
           V.ACMCOMPRAVENDA) in ( 'S',
                                  'I' )
  --AND V.codgeraloper IN (202,810,800,918,924,329,322,811,344,950,345,963)
--and V.NROEMPRESA = 2
--and V.DTAVDA BETWEEN Current_Date - 5 AND Current_Date - 4
--and V.DTAVDA between '01-mar-2025' and '30-apr-2025'
and V.DTAVDA > ?
group by
  A.SEQPRODUTO,
  V.NROSEGMENTO,
  V.NROEMPRESA,
  A.DESCCOMPLETA,
  A.SEQPRODUTO,
  A.DESCCOMPLETA,
  A.DESCCOMPLETA,
  to_number( null ),
  K.QTDEMBALAGEM,
  K.EMBALAGEM ||
  ' ' ||
  K.QTDEMBALAGEM,
  K.LITROS,
  V.DTAVDA,
  to_char(DTAHORLANCTO,'hh24'),
  NVL(GP1.DESCRICAO,'** Sem Grupo de Promoções **'), --jefferson
  PR1.PROMOCAO , --jefferson
  PR1.SEQPROMOCAO , --jeferson
  GP1.SEQGRUPOPROMOC
*/</note>
