    <connection>BI_207</connection>
    <sql>SELECT
  IDEMPRESA as FILIAL
, REGIAO
, NOMEREDUZIDO
, CASE 
	WHEN (IDEMPRESA = 28 OR IDEMPRESA = 5 OR IDEMPRESA = 6) THEN 'Depósito' 
	WHEN (IDEMPRESA = 999) THEN 'Outros' 
	ELSE 'Loja' END AS RATEIO
FROM dbo.dim_filiais
</sql>
