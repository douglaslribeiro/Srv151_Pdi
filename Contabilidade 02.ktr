  <step>
    <name>tmp_contabilidade_01, 02,  03, 04 e 05</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>BI_207</connection>
    <sql>/*
DROP TABLE #TEMP
DROP TABLE #TEMP2
DROP TABLE #TEMP3
DROP TABLE #TEMP4
DROP TABLE #TEMP5
*/

SELECT [NROEMPRESA]
      ,[ORIGEM]
      ,[NATUREZA_O]
      ,[NATUREZA_FI]
      ,CASE WHEN LEFT(HISTORICO,4)= '1253'  THEN 'ENERGIA ELETRICA' ELSE NATUREZA_F END NATUREZA_F     
      ,[HISTORICO]
      ,[DTALANCAMENTO]
      ,[LOTE]
      ,[FILIAL]
      ,A.[LANCAMENTO]
      ,[CONTADB]
      ,[TIPOENTIDADEDB]
      ,[CODENTIDADEDB]
      ,[CENTROCUSTODB]
      ,[CONTACR]
      ,[TIPOENTIDADECR]
      ,[CODENTIDADECR]
      ,[CENTROCUSTOCR]
      ,[VALOR]
      ,[IMPORTADODE]
      ,[VALORMOEDA]
      ,[LINKEXTERNO]
      ,[DTACONCILIOU]
      ,[USUCONCILIOU]
      ,[DTACANCELOU]
      ,[USUCANCELOU]
      ,[IDENTTABELA]
      ,[USUALTERACAO]
      ,[DTAALTERACAO]
      ,[LANCTOALTERADO]
      ,[PROCESSOCTB]
      ,[NRODOCUMENTO]
      ,[CODHISTORICO]
      ,[NROPLANILHA]
      ,[LANCTOREVERTIDO]
      ,[PROCESSOCTB_ANTIGO]
      ,[CODIGOFINANCEIRO]
      ,[HISTORICOPADRAO]
      ,[XX_CONTA]
      ,[MODULO]
      ,[NROPROCESSO]
      ,[CODOPERACAO]
      INTO #temp
  FROM [BI].[dbo].[tmp_contabilidade_01] a
  LEFT JOIN [dbo].[tmp_contabilidade_02] b ON A.LANCAMENTO = B.LANCAMENTO 

SELECT 
     CONCAT(RTRIM(LTRIM(NATUREZA_O)), RTRIM(LTRIM(NATUREZA_F)), RTRIM(LTRIM(NATUREZA_FI))) AS NATUREZA_01
    ,CONCAT(RTRIM(LTRIM(CENTROCUSTOCR)), RTRIM(LTRIM(CENTROCUSTODB))) AS CENTROCUSTO
    ,*
    INTO #TEMP2
FROM #TEMP

SELECT 
     CONCAT(RTRIM(LTRIM(NATUREZA_01)), RTRIM(LTRIM(NATUREZA_A))) AS NATUREZA
    ,a.*
    INTO #TEMP3
FROM #TEMP2 A
LEFT JOIN [dbo].[tmp_contabilidade_03] B 
ON A.LANCAMENTO = B.LANCAMENTO 
AND  RTRIM(LTRIM(A.HISTORICO)) = LTRIM(RTRIM(B.HISTORICO))
AND A.VALOR = B.VALOR
AND A.FILIAL = B.FILIAL
AND cast(A.DTALANCAMENTO  as date) = cast(B.DTALANCAMENTO as date)

SELECT 
    A.* 
    ,[OBSERVACAO]
    ,[HISTORICO_O]
    INTO #TEMP4
FROM #TEMP3 A
LEFT JOIN [dbo].[tmp_contabilidade_04] B ON A.PROCESSOCTB = B.NROPROCESSO

UPDATE #TEMP4
SET HISTORICO = HISTORICO_O
WHERE ORIGEM = 'O'

----------------
-- DROP TABLE #TEMP5
SELECT 
    A.* 
    ,DESCRICAO AS ESPECIE
    INTO #TEMP5
FROM #TEMP4 A
LEFT JOIN [dbo].[tmp_contabilidade_05] B ON A.PROCESSOCTB = B.NROPROCESSO
AND 
    A.HISTORICO = B.HISTORICO    
AND
    A.FILIAL = B.FILIAL
AND
    A.VALOR = B.VALOR    
AND 
    A.ORIGEM = 'FI'    
----------------------------

-- SELECT * FROM #TEMP5 WHERE ESPECIE &lt;&gt; ''

UPDATE #TEMP5
SET NATUREZA = ESPECIE
WHERE ORIGEM = 'FI' AND ESPECIE &lt;&gt; ''


SELECT * FROM #TEMP5 --#TEMP4

;

</sql>
