    <connection>CONSINCO 2025</connection>
    <sql>WITH TEMP_01
AS (
  SELECT 
      A.NUMERONF
    , A.SEQPESSOA
    , A.nroempresa
    , B.NOMEREDUZIDO
    , A.TIPNOTAFISCAL
    , CAST (A.DTAEMISSAO AS DATE) AS DTAEMISSAO 
    , CAST (A.DTAENTRADA AS DATE) AS DTAENTRADA 
    , A.SEQNF
    , A.CODGERALOPER
    , C.DESCRICAO
    , A.VLRTOTALNF
  FROM MLFV_NOTAFISCAL A
  INNER JOIN GE_EMPRESA B ON A.nroempresa = B.NROEMPRESA
  INNER JOIN max_codgeraloper C ON A.codgeraloper = C.CODGERALOPER
  WHERE A.SEQPESSOA IN (
        1214352
      , 1784895
      , 601
      , 600
      ) AND DTAEMISSAO >= '01-JAN-2026' AND TIPNOTAFISCAL = 'E'
  )
SELECT A.NOMERAZAO || ' / ' || A.SEQPESSOA AS FORNECEDOR, B.* FROM GE_PESSOA A
INNER JOIN TEMP_01 B ON A.seqpessoa = B.SEQPESSOA

</sql>
