    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>WITH TEMP_01
AS (
  SELECT 
      A.SEQNF
  FROM MLFV_NOTAFISCAL A
  WHERE A.SEQPESSOA IN (
        1214352
      , 1784895
      , 601
      , 600
      ) AND DTAEMISSAO >= '01-JAN-2026' AND TIPNOTAFISCAL = 'E'
  )
SELECT A.SEQNF, A.SEQPRODUTO, C.DESCCOMPLETA, A.QUANTIDADE, A.VLRITEM FROM TEMP_01 B 
INNER JOIN MLF_NFITEM A ON A.SEQNF = B.SEQNF
INNER JOIN MAP_PRODUTO C ON A.SEQPRODUTO = C.SEQPRODUTO

</sql>
