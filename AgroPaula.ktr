    <connection>CONSINCO 2025</connection>
    <sql>select
  a.* ,
  b.*
from
  mfl_doctofiscal a
inner join
  mfl_dfitem b
on
  a.seqnf = b.seqnf
and a.nroempresa in( 600,
                     601 )
and (a.dtamovimento >= TO_DATE('01-08-2025', 'DD-MM-YYYY') and a.dtamovimento &lt; TRUNC(SYSDATE))--('01-08-2025', 'DD-MM-YYYY')
and a.dtacancelamento is null
--and rownum &lt; 11</sql>
