  <step>
    <name>Clientes</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>WITH TEMP_01 AS
  (
    SELECT DISTINCT
      A.SEQPESSOA
    FROM
      MFL_DOCTOFISCAL A
    INNER JOIN
      MFL_DFITEM B
    ON
      A.SEQNF = B.SEQNF
    AND A.NROEMPRESA IN( 600,
                         601 )
    AND A.DTAMOVIMENTO >= TO_DATE('01-08-2025', 'DD-MM-YYYY')
    AND A.DTACANCELAMENTO IS NULL )
SELECT
  A.SEQPESSOA    ,
  B.NOMERAZAO    ,
  B.FANTASIA     ,
  B.CIDADE       ,
  B.BAIRRO       ,
  B.LOGRADOURO   ,
  B.NROLOGRADOURO,
  B.NROCGCCPF||
  DIGCGCCPF AS CGC_CPF
FROM
  TEMP_01 A
LEFT JOIN
  GE_PESSOA B
ON
  A.SEQPESSOA = B.SEQPESSOA

-- select * from GE_PESSOA </sql>
    <limit>0</limit>
    <lookup/>
