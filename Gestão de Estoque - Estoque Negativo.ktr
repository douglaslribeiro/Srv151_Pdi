  <step>
    <name>tmp_gestao_estoque_01</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>BI 238 DW</connection>
    <sql>WITH ranked_estoque AS (
    SELECT 
        "Id. Loja" as nroempresa,
        "Id. Produto" seqproduto,
        disponível,
        ROW_NUMBER() OVER (
            PARTITION BY "Id. Loja" 
            ORDER BY disponível ASC
        ) AS ranking
    FROM public.tmp_gestao_estoque_01 a
    inner join PUBLIC.dim_produto b on a."Id. Produto" = b.seqproduto and b.grupo &lt;&gt; 'VERDURAS'
    WHERE disponível &lt; 0
/*
    SELECT 
        "Id. Loja" as nroempresa,
        "Id. Produto" seqproduto,
        disponível,
        ROW_NUMBER() OVER (
            PARTITION BY "Id. Loja" 
            ORDER BY disponível ASC
        ) AS ranking
    FROM public.tmp_gestao_estoque_01
    WHERE disponível &lt; 0
*/
)
SELECT 
    a.nroempresa,
    a.seqproduto,
    disponível, 
    b.nomereduzido
FROM ranked_estoque a
INNER JOIN public.dim_loja b on a.nroempresa = b.nroempresa
WHERE ranking &lt;= 20
</sql>
    <limit>0</limit>
    <lookup/>
