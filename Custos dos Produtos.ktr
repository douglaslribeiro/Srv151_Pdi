  <step>
    <name>Custos dos Produtos</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>SELECT  
    g.NROEMPRESA,
    g.SEQPRODUTO,
    d.ESTQLOJA AS Estoque_Loja,
    d.CMULTVLRNF AS Custo_NF,
    d.CMULTICMSST AS ICMS_ST,
    d.CMULTDCTOFORANF AS Outros_Descontos,
    d.CMULTCREDPIS AS Cred_PIS,
    d.CMULTCREDCOFINS AS Cred_COFINS,
    d.CMULTIPI AS IPI,
    d.CMULTCREDPIS + d.CMULTCREDCOFINS + d.CMULTCREDICMS AS Cred_Fiscais,
    g.VLRCUSTOLIQUIDO as Custo_Liquido, 
    g.VLRCUSTOBRUTO as Custo_Bruto,
    d.CMULTCUSLIQUIDOEMP AS Custo_Fiscal,
    g.MGMLUCRO,
    g.PRECOGERNORMAL,
    g.PRECOGERPROMOC,
    g.PRECOBASENORMAL,
    g.PRECOVDANORMAL,
    g.PRECOMARGEM0
FROM mrlv_produtoempresa d
INNER JOIN mrl_prodempseg f 
    ON d.NROEMPRESA = f.NROEMPRESA 
    AND d.SEQPRODUTO = f.SEQPRODUTO
INNER JOIN maxv_mgmbaseprodseg g 
    ON f.NROSEGMENTO = g.NROSEGMENTO 
    AND f.NROEMPRESA = g.NROEMPRESA 
    AND f.SEQPRODUTO = g.SEQPRODUTO 
    AND f.QTDEMBALAGEM = g.QTDEMBALAGEM
WHERE EXISTS (
    SELECT 1 
    FROM map_produto a
    INNER JOIN map_famdivisao b ON a.SEQFAMILIA = b.SEQFAMILIA AND b.FINALIDADEFAMILIA = 'R'
    INNER JOIN mad_famsegmento c ON a.SEQFAMILIA = c.SEQFAMILIA AND c.STATUS = 'A'
    INNER JOIN max_empresa e ON b.NRODIVISAO = e.NRODIVISAO AND c.NROSEGMENTO = e.NROSEGMENTOPRINC
    WHERE a.SEQPRODUTO = d.SEQPRODUTO 
      AND e.NROEMPRESA = d.NROEMPRESA
      AND c.PADRAOEMBVENDA = f.QTDEMBALAGEM
)

/* 13.04.2026
select  
        g.NROEMPRESA,
        g.SEQPRODUTO,
        d.ESTQLOJA AS Estoque_Loja,
        d.CMULTVLRNF AS Custo_NF,
        d.CMULTICMSST AS ICMS_ST,
        d.CMULTDCTOFORANF AS Outros_Descontos,
        d.CMULTCREDPIS AS Cred_PIS,
        d.CMULTCREDCOFINS AS Cred_COFINS,
        d.CMULTIPI AS IPI,
        d.CMULTCREDPIS + d.CMULTCREDCOFINS + d.CMULTCREDICMS AS Cred_Fiscais,
        g.VLRCUSTOLIQUIDO as Custo_Liquido, 
        g.VLRCUSTOBRUTO as Custo_Bruto,
        d.CMULTCUSLIQUIDOEMP AS Custo_Fiscal,
        g.MGMLUCRO,
        g.PRECOGERNORMAL,
        g.PRECOGERPROMOC,
        g.PRECOBASENORMAL,
        g.PRECOVDANORMAL,
        g.PRECOMARGEM0
from map_produto a
inner join map_famdivisao b on a.seqfamilia = b.seqfamilia
inner join mad_famsegmento c on a.seqfamilia = c.seqfamilia
inner join mrlv_produtoempresa d on a.seqproduto = d.SEQPRODUTO
inner join mrl_prodempseg f on c.nrosegmento = f.nrosegmento
                           and d.NROEMPRESA = f.nroempresa
                           and d.SEQPRODUTO = f.seqproduto
                           and c.padraoembvenda = f.qtdembalagem
inner join maxv_mgmbaseprodseg g on b.nrodivisao = g.nrodivisao
                                and f.nrosegmento = g.nrosegmento
                                and f.nroempresa = g.nroempresa
                                and f.seqproduto = g.seqproduto
                                and f.qtdembalagem = g.qtdembalagem
inner join max_empresa e on b.nrodivisao = e.nrodivisao
                        and c.nrosegmento = e.nrosegmentoprinc
                        and d.NROEMPRESA  = e.nroempresa

where b.finalidadefamilia = 'R'
  and c.status            = 'A'
*/</sql>
