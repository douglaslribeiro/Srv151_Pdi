  <step>
    <name>Base PMZ e Custo Gerencial</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>SELECT *
FROM (
  WITH PMZ AS (
      SELECT AA.NRODIVISAO
        , AA.NROSEGMENTO
        , AA.NROEMPRESA
        , AA.SEQPRODUTO
        , AA.QTDEMBALAGEM
        , ROUND(DECODE(NVL(AA.propqtdprodutobase, 0), 0, AA.PRECOMARGEM0, AA.PRECOMARGEM0 * AA.propqtdprodutobase), 2) AS PRECOMARGEM0
        , AA.VLRCUSTOLIQUIDO
      FROM MAXV_MGMBASEPRODSEG AA
        , MAD_FAMSEGMENTO BB
        , MAX_EMPRESA CC
      WHERE AA.NROSEGMENTO = BB.NROSEGMENTO AND AA.SEQFAMILIA = BB.SEQFAMILIA AND AA.QTDEMBALAGEM = BB.PADRAOEMBVENDA AND AA.NRODIVISAO = CC.NRODIVISAO AND AA.NROSEGMENTO = CC.NROSEGMENTOPRINC AND AA.NROEMPRESA = CC.NROEMPRESA
      )
  SELECT 
      E.NROEMPRESA
    , A.SEQFAMILIA
    , A.SEQPRODUTO
    , G.QTDEMBALAGEM
    , G.EMBALAGEM
    , B.FAMILIA
    , A.DESCGENERICA
    , ROUND((I.PRECOMARGEM0 * G.QTDEMBALAGEM), 6) AS PRECOMARGEM0
    , ROUND((E.CMULTVLRNF * G.QTDEMBALAGEM), 6) AS CMULTVLRNF
    , ROUND((NVL(I.VLRCUSTOLIQUIDO, 0) * G.QTDEMBALAGEM), 6) CUSTOGERENCIAL
    , NVL(H.PRECOVALIDNORMAL, 0) AS PRECOVALIDNORMAL
    , ROUND(NVL(fc5margempreco(pnSeqProduto => h.seqproduto, pnNroEmpresa => H.NROEMPRESA, pnNroSegmento => H.NROSEGMENTO, pnQtdEmbalagem => H.QTDEMBALAGEM, pnCusto => I.VLRCUSTOLIQUIDO, pnPreco => DECODE(NVL(H.PRECOVALIDPROMOC, 0), 0, H.PRECOVALIDNORMAL, H.PRECOVALIDPROMOC), pnPercComissaoInformada => NULL, psIndSomaIcmsCustoMesBase => NULL), 0), 2) AS MGMPRATICADA
    , NVL(H.PRECOVALIDPROMOC, 0) AS PRECOVALIDPROMOC
    , NVL(H.STATUSVENDA, 'I') AS STATUSVENDA
  FROM MAP_PRODUTO A
    , MAP_FAMILIA B
    , MAP_FAMDIVISAO C
    , MAD_FAMSEGMENTO D
    , MRLV_PRODUTOEMPRESA E
    , MAX_EMPRESA F
    , MAP_FAMEMBALAGEM G
    , MRL_PRODEMPSEG H
    , PMZ I
  WHERE
    /*JOIN*/
    A.SEQFAMILIA = B.SEQFAMILIA AND A.SEQFAMILIA = C.SEQFAMILIA AND A.SEQFAMILIA = D.SEQFAMILIA AND A.SEQPRODUTO = E.SEQPRODUTO AND C.NRODIVISAO = F.NRODIVISAO AND D.NROSEGMENTO = F.NROSEGMENTOPRINC AND E.NROEMPRESA = F.NROEMPRESA AND A.SEQFAMILIA = G.SEQFAMILIA AND F.NROSEGMENTOPRINC = H.NROSEGMENTO(+) AND E.NROEMPRESA = H.NROEMPRESA(+) AND A.SEQPRODUTO = H.SEQPRODUTO(+) AND G.QTDEMBALAGEM = H.QTDEMBALAGEM(+) AND F.NRODIVISAO = I.NRODIVISAO AND F.NROSEGMENTOPRINC = I.NROSEGMENTO AND F.NROEMPRESA = I.NROEMPRESA AND A.SEQPRODUTO = I.SEQPRODUTO
    /*FILTROS*/
    AND C.FINALIDADEFAMILIA = 'R' AND D.STATUS = 'A' AND G.STATUS = 'A' AND NVL(H.STATUSVENDA, 'I') IN ( 'A' ) AND F.NROEMPRESA IN ( 20, 22 )
    AND G.EMBALAGEM IN ('UN', 'KG')
    --*************
    --AND A.SEQPRODUTO = 11805
    --*************
  )

</sql>
