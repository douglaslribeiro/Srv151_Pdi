    <sql>select
  a."Id. Loja"    ,
  a."Id. Produto" ,
  a.disponível
from
  public.tmp_gestao_estoque_01 a
inner join
  public.dim_produto b
on
  a."Id. Produto"    = b.seqproduto
and b.situacaocompra = 'ATIVO'
--and a.disponível     &lt;&gt; 0



</sql>
