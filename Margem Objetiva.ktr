    <sql>select a.seqfamilia,
       a.seqproduto,
       a.produto,
       --a.familia,
       a.nomereduzido,
       a.mgmlucrofamemp,
       a.margem,
       a.ativo,
       a.pmz,
       a.custo_gerencial
from qview_mgmlucrofamporempresa a
where a.nroempresa IN (20,22)
--and seqfamilia = 13643
 /*( case
                         when to_number(:NR1) = 0 then ( select nroempresa
                                                         from ge_empresa
                                                         where matriz = 6
                                                           and nroempresa = a.nroempresa )
                       else to_number(:NR1)
                       end )
