  <step>
    <name>dim_usuario_grupo 3</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>WITH lista as
     (     SELECT
           a.seqpessoa ,
           a.sequsuario,
           a.nome      ,
           a.codusuario,
           a.nivel,
           a.email,
           a.dtaultacesso,
           a.dtavalidacao,
           a.dtahorainclusao,
           a.dtahoralteracao,
           a.dtlimiteuso
        FROM
           ge_usuario a
     )
select
   lista.seqpessoa               ,
   lista.sequsuario              ,
   lista.nome  as nome_usuario   ,
   lista.codusuario              ,
   LPAD(TO_CHAR(P.NROCGCCPF), 9, '0') ||LPAD(TO_CHAR(P.DIGCGCCPF), 2, '0') AS cpf,
   lista.email                   ,  
   lista.nivel                   ,
   DECODE(lista.nivel,
          0          , 'Bloqueado'    ,
          1          , 'Visitante'    ,
          2          , 'Trainee'      ,
          3          , 'Usuário'      ,
          4          , 'Líder'        ,
          5          , 'Gerente'      ,
          7          , 'Diretor'      ,
          8          , 'Administrador',
          lista.nivel ) AS descricao_nivel,
   decode ( lista.nivel,
            0          , 'INATIVO',
            'ATIVO') as status        ,
lista.dtaultacesso,
lista.dtavalidacao,
lista.dtahorainclusao,
lista.dtahoralteracao,
lista.dtlimiteuso
from
   lista
left JOIN GE_PESSOA P ON lista.seqpessoa = P.SEQPESSOA   
</sql>
