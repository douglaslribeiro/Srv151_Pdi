  <step>
    <name>consincomonitor.vw_logsegurancapdv</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>select       distinct
             d.nroempresaerp as nroempresa,
             a.sequsuario,
             a.nome,
             a.operacao,
             CASE 
                  WHEN a.operacao =  'Cancelamento do documento anterior'                                      THEN 'Cancelamento do cupom'
                  WHEN a.operacao IN ('Consulta produto', 'Consulta preço')                                    THEN 'Consulta'
                  WHEN a.operacao IN ('Desconto no item com diferença de preço', 'Desconto no item anterior')  THEN 'Desconto no item'
                  WHEN a.operacao =  'Cancelamento do item do cupom'                                           THEN 'Cancelamento do item'
                  WHEN a.operacao =  'Liberar multiplicação no cupom'                                          THEN 'Multiplicação'
                  WHEN a.operacao =  'Saída temporária'                                                        THEN 'Pausa'
                  ELSE a.operacao 
             END AS operacao2,
             a.nrocheckout,
             a.serie,
             a.cro,
             a.coo,
             a.seqitem,
             a.codacesso,
             a.valor,
             a.motivo,
             a.observacao,
             c.nome as nomeseg,
			 to_char(a.dtamovimento,'DD-MM-YYYY')  as dtamovimento,
             to_char(a.dtahoremissao,'HH24:MI:SS') as horaemissao,
             a.dtahoremissao             
        from consincomonitor.vw_logsegurancapdv a,
             consincomonitor.tb_logsegusuariopdv b,
             consincomonitor.tb_usuario c,
             consincomonitor.tb_empresa d
       where 
             b.nroempresa(+)  = a.nroempresa
         and b.nrocheckout(+) = a.nrocheckout
         and b.seqlogsegpdv(+)= a.seqlogsegpdv
         and c.sequsuario(+)  = b.sequsuario
         and d.nroempresa     = a.nroempresa
         and lower(a.operacao) not like 'pagamento_%'
         --and TRUNC(a.dtahoremissao) BETWEEN ? + 1     AND TRUNC(SYSDATE)-1
         --and TRUNC(a.dtahoremissao) BETWEEN TRUNC(TO_DATE('27-03-2025', 'DD-MM-YYYY')) + 1 AND TRUNC(SYSDATE) - 1
         --and d.nroempresaerp = 7
         --and trunc(a.dtahoremissao) between '02-04-2025' and '02-04-2025'
		and TRUNC(a.dtahoremissao) = TRUNC(SYSDATE)
   </sql>
