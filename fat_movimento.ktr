  <step>
    <name>Mrl_LanctoEstoque</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>Select
   a.DTAENTRADASAIDA       ,
   a.DTAHORLANCTO          ,  
   a.NROEMPRESA            ,
   a.CODGERALOPER          ,
   a.SEQPRODUTO            ,
   --sum (a.QTDLANCTO )as QTDLANCTO,
  SUM(
  CASE 
    WHEN a.tiplancto = 'S' THEN a.QTDLANCTO * -1
    ELSE a.QTDLANCTO
  END
    ) AS QTDLANCTO,
   sum (a.QTDPRODBASE ) as  QTDPRODBASE,
   Sum((a.valorvlrnf + a.valoripi + a.valordespnf + a.valoricmsst  + a.valordespforanf - (a.valordctoforanf - nvl(a.vlricmspresumido, 0))) * decode( a.tiplancto, 'S', -1, 1 )) as VlrBr,
   a.LOCAL                 ,
   a.NRODOCUMENTO          ,
   a.SEQMOVTOESTQ          ,
   a.NROSEGMENTO           ,
   a.TIPLANCTO             ,
   a.TIPUSOCGO             ,
   a.USULANCTO             ,
   a.GERALTERACAOESTQ      ,
   a.GERALTERACAOESTQFISC  ,
   a.HISTORICO             ,
   a.MOTIVOMOVTO           ,
   a.PERDESPOPERACIONALITEM,
   a.SEQLANCTOAVARIA       ,
   a.SEQLOTEESTOQUE        ,
   a.SEQMOVTOORIG          ,
   a.SEQOPERADOR           , 
   a.SEQPRODUTOBASE        
                
/*   a.valordctoforanf       ,
   a.valordespforanf       ,
   a.valordespforanf       ,
   a.valordespnf           ,
   a.valordespnf           ,
   a.valoricmsst           ,
   a.valoricmsst           ,
   a.valoripi              ,
   a.valoripi              ,
   a.valorvlrnf            ,
   a.valorvlrnf            ,
   a.vlricmspresumido,*/
 --Sum((a.valorvlrnf + a.valoripi + a.valordespnf + a.valoricmsst  + a.valordespforanf - nvl(a.vlricmspresumido, 0)) * decode( a.tiplancto, 'E', -1, 1 )) as Vlr
   from
   Mrl_LanctoEstoque a
where
   a.codgeraloper !=800
and a.dtaentradasaida >= TRUNC(SYSDATE) - 62
--and a.dtaentradasaida BETWEEN '26-02-2026' and '26-02-2026'
--and a.nroempresa = 3
--and a.SEQPRODUTO =9844
group by    
a.DTAENTRADASAIDA,
a.DTAHORLANCTO,
a.NROEMPRESA            ,
a.CODGERALOPER           ,
a.SEQPRODUTO          ,
a.GERALTERACAOESTQ      ,
   a.GERALTERACAOESTQFISC  ,
   a.HISTORICO             ,
   a.LOCAL                          ,
   a.MOTIVOMOVTO            ,
   a.NRODOCUMENTO          ,
   a.NROSEGMENTO         ,
   a.PERDESPOPERACIONALITEM,
  a.SEQLANCTOAVARIA       ,
   a.SEQLOTEESTOQUE        ,
   a.SEQMOVTOESTQ          ,
   a.SEQMOVTOORIG          ,
   a.SEQOPERADOR           , 
   a.SEQPRODUTOBASE        ,
   a.TIPLANCTO             ,
   a.tiplancto             ,
   a.tiplancto             ,
   a.TIPUSOCGO             ,
   a.USULANCTO             </sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta>
      <value-meta>
