  <step>
    <name>msu_pedidosuprim 42</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>select
   a.nropedidosuprim
   ,a.nroempresa
   ,a.centralloja
   ,a.seqcomprador
   ,d.apelido
   ,a.seqfornecedor
   ,fnnomepessoa(a.seqfornecedor) nmfornecedor
   ,a.tippedidosuprim
   ,b.seqproduto
   ,b.qtdembalagem
   ,b.qtdsolicitada
   ,c.qtdrecebida
   ,c.qtdcancelada
   ,c.qtdtransito
   ,c.qtdetotrecebnf
   ,b.vlrembitem
   ,c.vlrproduto
   ,b.vlrembipi
   ,c.vlripi
   ,b.vlrembicmsst
   ,c.vlricmsst
   ,b.vlrembicms
   ,c.vlricms
   ,b.vlrembirrf
   ,c.vlrirrf
   ,b.vlrembdesconto
   ,c.vlrdesconto
   ,b.vlrembdespesa
   ,c.vlrdespesa
   ,b.vlrembverbacompra
   ,b.statusitem
   ,a.situacaoped
   ,a.dtaemissao
   ,c.dtainclusao
   ,a.dtalimiterecebto
   ,c.dtahorcancelamento
   ,c.numeronf
   ,c.seqpessoa
   ,fnnomepessoa(c.seqpessoa) nmpessoa
from msu_pedidosuprim a
inner join msu_psitemreceber b
   on a.nropedidosuprim = b.nropedidosuprim
   and a.nroempresa = b.nroempresa
   and a.centralloja = b.centralloja
   and trunc(a.dtaemissao) = trunc(b.dtaaprovacao)
left join msu_psitemrecebido c
   on a.nropedidosuprim = c.nropedidosuprim
   and a.nroempresa = c.nroempresa
   and a.centralloja = c.centralloja
   and b.seqproduto = c.seqproduto
inner join max_comprador d
   on a.seqcomprador = d.seqcomprador
where
   a.nroempresa IN (42)
   and a.dtaemissao >= '01-oct-2025'
   and a.tippedidosuprim IN ('C','c')

</sql>
