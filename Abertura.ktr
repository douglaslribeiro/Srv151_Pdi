  <step>
    <name>Detalhes do Estoque 42</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>SELECT 
     Decode(c.FORMAABASTECIMENTO, 'M', 'Centralizado', 'C', 'CCEDL', 'L', 'EDL', 'I', 'CrossDocking', 'P', 'Produção Interna') AS FormaAbastec
	,a.QTDPENDPEDCOMPRA
	,a.DTAULTENTRADA
    ,a.NROEMPRESA
    ,A.SEQPRODUTO
FROM MRLV_PRODUTOEMPRESA a
	,Map_Produto b
	,MAP_FAMDIVISAO c
WHERE a.SeqPRoduto = b.SeqProduto
	AND b.SeqFamilia = c.SeqFamilia
	AND c.NRODIVISAO = 1
	AND NROEMPRESA = 42 
</sql>
