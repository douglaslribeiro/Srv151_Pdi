    <connection>CONSINCO 2025</connection>
    <sql>
select
   a.nropedidosuprim
   ,a.nropedfornecedor
   ,a.nroempresa
   ,a.centralloja
   ,a.seqcomprador
   ,b.comprador nmcomprador
   ,a.seqfornecedor
   ,fnnomeempresareduzido(a.seqfornecedor) nmfornecedor
   ,a.tippedidosuprim
   ,c.seqproduto
   ,c.qtdembalagem
   ,c.qtdsolicitada
   
   ,d.dtainclusao

   ,(c.qtdembalagem * pkg_alvorada.FNCMDIAVLRNF(c.nroempresa,c.seqproduto))vlrembitem
   ,pkg_alvorada.FNCMDIAVLRNF(c.nroempresa,c.seqproduto) vlritem
   ,nvl(d.qtdexpedida,0) qtdexpedida
   ,nvl(d.qtdcortepedvenda,0) qtdcortepedvenda
   ,nvl(d.qtdcorteetqvol,0) qtdcorteetqvol
   ,nvl(d.qtdcancelada,0) qtdcancelada
   ,nvl(d.qtdtransito,0) qtdtransito
   ,d.nropedvenda
   ,d.numeronf
   ,d.serienf
   ,a.situacaoped
   ,c.statusitem
   ,a.dtaemissao
   ,d.dtahorcancelamento
from msu_pedidosuprim a
inner join max_comprador b
   on a.seqcomprador = b.seqcomprador
inner join msu_psitemexpedir c
   on a.nropedfornecedor = c.nropedidosuprim
   and a.nroempresa = c.nroempdestino
   and a.centralloja = c.centralloja
left join msu_psitemexpedido d
   on a.nropedfornecedor = d.nropedidosuprim
   and a.nroempresa = d.nroempdestino
   and a.centralloja = d.centralloja
   and c.seqproduto = d.seqproduto
where 
   a.nroempresa in (42)
   and a.dtaemissao >= '01-oct-2025'
   and a.tippedidosuprim in('T','t')</sql>
