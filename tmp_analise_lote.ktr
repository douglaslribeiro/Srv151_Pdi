    <connection>CONSINCO 2025</connection>
    <sql>SELECT A.NROEMPRESA,	
       A.DTAHORGERACAO,
       A.STATUS,
       A.INDVALIDACAO,
       A.SEQLOTE,
       A.LOTEINVFISICO,
       A.SEQPRODUTO,
       A.ITENSTOTAL,
       A.ITENSDIVERG,
       A.CTOLIQSISTEMA,
       A.CTOBRUTOSISTEMA,
       A.PRECOTOTALSISTEMA,
       A.CTOLIQCONTADO,
       A.CTOBRUTOCONTADO,
       A.PRECOTOTALCONTATO,
       A.CTOLIQDIVERG,
       A.CTOBRUTODIVERG,
       A.PRECOTOTALDIVERG,
       A.INDTRANSFPEND,
       A.QTDPRODPEND,
       A.QTDGERSISTEMA,
       A.QTDCONTADA,
       A.QTDDIVERGENCIA
FROM QVIEW_ANALISELOTINVENT A
WHERE 
trunc (A.DTAHORGERACAO)BETWEEN trunc (SYSDATE - 40) AND  trunc (SYSDATE)
--A.DTAHORGERACAO between to_date('09/10/2024','dd/mm/yyyy') and to_date('09/10/2024','dd/mm/yyyy')
     </sql>
