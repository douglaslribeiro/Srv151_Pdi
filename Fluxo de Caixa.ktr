    <connection>CONSINCO 2025</connection>
    <sql>WITH CC
AS (
	SELECT DISTINCT SEQCTACORRENTE
	FROM qview_fluxo_caixa
	)
SELECT 
      A.SEQCTACORRENTE
	, A.CODIGOFATOR
	, A.NROBANCO
	, A.SEQAGENCIA
	, A.NROEMPRESA
	, A.NROEMPRESAMAE
	, A.SITUACAO
	, A.DESCRICAO
	, A.NROCONTA
	, A.DIGCONTA
	, A.TIPOCONTA
	, A.NROULTCHEQUE
	, A.SERIEULTCHEQUE
	, A.SOMARFLXCXA
	, A.LIMITECREDITO
	, A.DTALIMCRED
	, A.PDRFORMCHEQUE
	, A.CTACONTABIL
	, A.TIPOENTIDADE
	, A.CODENTIDADE
	, A.CENTRORESULTADO
	, A.SALDOATUAL
	, A.VLRPROVREC
	, A.VLRPROVPGTO
	, A.TABLINK
	, A.CODLINK
	, A.CAIXAMASTER
	, A.SITCAIXA
	, A.DTAABERTURACXA
	, A.DTAALTERACAO
	, A.USUALTERACAO
	, A.SEQPESSOANOTA
	, A.PORTAIMPRESSORA
	, A.USACONCELETR
	, A.USACUSTODIAELETR
	, A.CODMODELO
	, A.NROREMESSA
	, A.EMITECHEQUE
	, A.NROULTREMCUSTODIA
	, A.SEQPESSOACAIXA
	, A.CTACREDITO
	, A.CTACREDITODEP
	, A.SEQGRUPO
	, A.EXIGETALAO
	, A.LIBERALIMCRED
	, A.SEQCTACORRENTEREMESSA
	, A.INDUTILIZADATAMOVTO
	, A.INDCTAPADRAOANTECIP
	, A.DIRETORIOARQCONC
	, A.SEQEXPFLUXOCAIXA
	, A.DIRARQPROC
	, A.SEQCTACORRENTE
FROM FI_CTACORRENTE A
INNER JOIN CC B ON A.SEQCTACORRENTE = B.SEQCTACORRENTE
</sql>
