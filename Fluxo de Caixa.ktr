    <connection>CONSINCO 2025</connection>
    <sql>SELECT 
      CODOPERACAO
	, OPERACAO
	, DESCRICAO
	, SEQCTACORRENTE
	, CTACORRENTE
	, HISTORICO
	, CASE WHEN TIPOLANCTO = 'D' THEN VLROPERACAO * -1  ELSE VLROPERACAO END VLROPERACAO
	, TIPOLANCTO
	, DTALANCTO
	, NROPROCESSO
	, ORIGEMDOC
	, NOMERAZAO
	, ESPECIE
    , NROEMPRESAMAE
FROM qview_fluxo_caixa
WHERE DTALANCTO >= '01-jul-2025'
ORDER BY NROPROCESSO
</sql>
