  <step>
    <name>Saldos por Dia</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>SELECT 
    SEQCTACORRENTE, 
    CAST(DATA AS DATE) DT_MOVIMENTO, 
    LAG(SALDO) OVER (PARTITION BY SEQCTACORRENTE ORDER BY DATA) AS SALDO_ANTERIOR,
    VLRCREDITO, 
    VLRDEBITO * -1 as VLRDEBITO, 
    SALDO AS SALDO_ATUAL
FROM FI_CTACORRENTESALDO 
WHERE Data >= '01-JUL-2025' 
ORDER BY SEQCTACORRENTE, DATA

