  <step>
    <name>ENTRADA DE INDUSTRIA</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>/* 
Vindo da QueryView MaxRio > Dados de Tributação por Família - Antonio Matos
*/

select 
       --dtaalteracao_pauta,
       divisao,
       tributacao, 
       tipotributacao,
       regimetribespecial,
       fornecedor,
       seqproduto, 
       produto, 
       ean, 
       dun, 
       ncm, 
       cest, 
       cstpisent, 
       cstcofinsent, 
       cstpissai, 
       cstcofinssai, 
       codnatrec,
       ufempresa, 
       ufclientefornec, 
       perisento perredbasecalc, 
       peraliquota peraliqicms, 
       peraliqfcpicms, 
       mva, 
       peraliquotast, 
       peraliqfcpst, 
       aliquotaipi,
       peraliqpis,
       peraliqcofins
       pauta, 
       uforigem, 
       ufdestino, 
       vlrbasest, 
       fatorconversao, 
       tipocalcpauta, 
       dtainicio, 
       dtafim     
from qview_base_famtributacao --a
where divisao = 'VAREJO' AND tipotributacao = 'ENTRADA DE INDUSTRIA' AND regimetribespecial LIKE 'FORNEC/CLIENT%'
</sql>
