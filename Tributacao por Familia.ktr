    <connection>CONSINCO 2025</connection>
    <sql>/* 
Vindo da QueryView MaxRio > Dados de Tributação por Família - Antonio Matos
*/

select 
       --dtaalteracao_pauta,
       divisao,
       tributacao, 
       tipotributacao,
       regimetribespecial,
       fornecedor,
       seqproduto, 
       produto, 
       ean, 
       dun, 
       ncm, 
       cest, 
       cstpisent, 
       cstcofinsent, 
       cstpissai, 
       cstcofinssai, 
       codnatrec,
       ufempresa, 
       ufclientefornec, 
       perisento perredbasecalc, 
       peraliquota peraliqicms, 
       peraliqfcpicms, 
       mva, 
       peraliquotast, 
       peraliqfcpst, 
       aliquotaipi,
       peraliqpis,
       peraliqcofins
       pauta, 
       uforigem, 
       ufdestino, 
       vlrbasest, 
       fatorconversao, 
       tipocalcpauta, 
       dtainicio, 
       dtafim     
--from qview_base_famtributacao_v2 a
from qview_base_famtributacao --a
where divisao = 'VAREJO' AND tipotributacao = 'ENTRADA DE DISTRIBUIDOR' AND regimetribespecial LIKE 'FORNEC/CLIENT%'
--where dtaalteracao_pauta >= '01-jan-2026'
--where uforigem is not null
--where regimetribespecial = 'FORNEC/CLIENT/LEI 9.025- S.LOG'
-- rownum &lt; 1001
--where a.regimetribespecial = #LS1 and a.tipotributacao = #LS2 and a.divisao = #LS3
</sql>
