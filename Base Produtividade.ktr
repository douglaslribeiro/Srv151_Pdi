    <connection>CONSINCO</connection>
    <sql>SELECT
    NROEMPRESA, 
	NROCHECKOUT, 
	SEQDOCTO, 
	IND_CANCELADO, 
	DTAMOVIMENTO, 
	SERIE, 
	COO, 
	SEQUSUARIO, 
