	VLRCANCELADO, 
	VLRDESCONTO, 
	VLRACRESCIMO, 
    VLRTOTAL
FROM qview_cia_baseprodutividade
WHERE dtamovimento >= ADD_MONTHS(TRUNC(SYSDATE, 'MM'), ?)
--FETCH FIRST 10 ROW ONLY</sql>
