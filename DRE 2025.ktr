  <step>
    <name>DRE - Detalhes</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>SOLIDCON_BI</connection>
    <sql>SELECT *
FROM BI.contabilidade.fat_dre_2021_2024
WHERE YEAR(DTALANCAMENTO) BETWEEN 2021 AND 2024
    AND MONTH(DTALANCAMENTO) BETWEEN 1 AND 12

union all

SELECT *
FROM BI.contabilidade.fat_dre_2025_01A08
WHERE YEAR(DTALANCAMENTO) = 2025
    AND MONTH(DTALANCAMENTO) BETWEEN 1 AND 8

union all

SELECT *
FROM BI.dbo.[fat.dre]    
WHERE YEAR(DTALANCAMENTO) BETWEEN 2025 AND 2030
</sql>
