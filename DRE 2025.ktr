    <connection>SOLIDCON_BI</connection>
    <sql>SELECT 
    YEAR(DTALANCAMENTO) AS ANO,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 1 THEN VALOR ELSE 0 END), 2) AS JAN,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 2 THEN VALOR ELSE 0 END), 2) AS FEV,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 3 THEN VALOR ELSE 0 END), 2) AS MAR,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 4 THEN VALOR ELSE 0 END), 2) AS ABR,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 5 THEN VALOR ELSE 0 END), 2) AS MAI,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 6 THEN VALOR ELSE 0 END), 2) AS JUN,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 7 THEN VALOR ELSE 0 END), 2) AS JUL,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 8 THEN VALOR ELSE 0 END), 2) AS AGO,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 9 THEN VALOR ELSE 0 END), 2) AS STB,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 10 THEN VALOR ELSE 0 END), 2) AS OUT,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 11 THEN VALOR ELSE 0 END), 2) AS NOV,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 12 THEN VALOR ELSE 0 END), 2) AS DEZ
FROM BI.contabilidade.fat_dre_2021_2024
WHERE YEAR(DTALANCAMENTO) BETWEEN 2021 AND 2024
    AND MONTH(DTALANCAMENTO) BETWEEN 1 AND 12
    AND NROEMPRESA = 6
GROUP BY YEAR(DTALANCAMENTO)
--ORDER BY ANO;
 
union all
---------------------------------

SELECT 
    YEAR(DTALANCAMENTO) AS ANO,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 1 THEN VALOR ELSE 0 END), 2) AS JAN,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 2 THEN VALOR ELSE 0 END), 2) AS FEV,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 3 THEN VALOR ELSE 0 END), 2) AS MAR,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 4 THEN VALOR ELSE 0 END), 2) AS ABR,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 5 THEN VALOR ELSE 0 END), 2) AS MAI,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 6 THEN VALOR ELSE 0 END), 2) AS JUN,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 7 THEN VALOR ELSE 0 END), 2) AS JUL,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 8 THEN VALOR ELSE 0 END), 2) AS AGO,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 9 THEN VALOR ELSE 0 END), 2) AS STB,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 10 THEN VALOR ELSE 0 END), 2) AS OUT,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 11 THEN VALOR ELSE 0 END), 2) AS NOV,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 12 THEN VALOR ELSE 0 END), 2) AS DEZ
FROM BI.contabilidade.fat_dre_2025_01A08
WHERE 
    NROEMPRESA = 6
GROUP BY YEAR(DTALANCAMENTO)
-- FROM BI.contabilidade.fat_dre_2025_01A08

union all

SELECT 
    YEAR(DTALANCAMENTO) AS ANO,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 1 THEN VALOR ELSE 0 END), 2) AS JAN,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 2 THEN VALOR ELSE 0 END), 2) AS FEV,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 3 THEN VALOR ELSE 0 END), 2) AS MAR,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 4 THEN VALOR ELSE 0 END), 2) AS ABR,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 5 THEN VALOR ELSE 0 END), 2) AS MAI,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 6 THEN VALOR ELSE 0 END), 2) AS JUN,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 7 THEN VALOR ELSE 0 END), 2) AS JUL,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 8 THEN VALOR ELSE 0 END), 2) AS AGO,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 9 THEN VALOR ELSE 0 END), 2) AS STB,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 10 THEN VALOR ELSE 0 END), 2) AS OUT,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 11 THEN VALOR ELSE 0 END), 2) AS NOV,
    ROUND(SUM(CASE WHEN MONTH(DTALANCAMENTO) = 12 THEN VALOR ELSE 0 END), 2) AS DEZ
-- FROM BI.contabilidade.fat_dre_2021_2024
FROM BI.dbo.[fat.dre]    
WHERE YEAR(DTALANCAMENTO) BETWEEN 2025 AND 2030
    --AND MONTH(DTALANCAMENTO) BETWEEN 1 AND 8
    AND NROEMPRESA = 6
GROUP BY YEAR(DTALANCAMENTO)
ORDER BY ANO;</sql>
