  <step>
    <name>Mad_PedVenda / Mrl_CargaExped</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>/* == CONSULTA ALVORADA == */
SELECT Substr(h.NomeReduzido, 5, 4) AS FilialAbrev
	,CASE 
		WHEN (
				PedExped.TipoLote IN (
					 'C'
					,'B'
					,'E'
					)
				AND PedExped.SeqFornecedor != 6
				)
			OR PedExped.SeqFornecedor IS NOT NULL
			THEN 'Cross-Docking'
		WHEN PedExped.SeqFornecedor IS NULL
			THEN 'Centralizado'
		END AS Tip_Separacao
	,g.CodDeposSepar AS Deposito
	,b.SituacaoPed AS ID_Situacao
	,b.UsuInclusao AS Usuario_Inclusao
	,b.UsuAlteracao AS Usuario_Alteracao
	,Substr(fNomeCompletoCategoria(c.SeqFamilia, 1), 0, 240) AS Categoria
	,h.NroEmpresa AS Filial
	,h.NomeReduzido
	,(
		SELECT COUNT(*)
		FROM DUAL
		WHERE To_Char((
					CASE 
						WHEN PedExped.TipoLote IN (
								 'C'
								,'B'
								,'E'
								)
							THEN b.DtaInclusao
						ELSE Nvl(PedExped.DtaEmissao, b.Dtainclusao)
						END
					) + LEVEL - 1, 'DY') NOT IN ('SAT') CONNECT BY LEVEL &lt;= (trunc(sysdate) - 1) - (
				CASE 
					WHEN PedExped.TipoLote IN (
							'C'
							,'B'
							,'E'
							)
						THEN b.DtaInclusao
					ELSE Nvl(PedExped.DtaEmissao, b.Dtainclusao)
					END
				) + 1
		) dias_uteis
	,CASE 
		WHEN PedExped.TipoLote IN (
				'C'
				,'B'
				,'E'
				)
			THEN To_Char(b.DtaInclusao, 'DD/MM/YYYY')
		ELSE To_Char(Nvl(PedExped.DtaEmissao, b.Dtainclusao), 'DD/MM/YYYY')
		END AS DataPedido
	,a.NroPedVenda AS Pedido
	,CASE 
		WHEN PedExped.TipoLote IN (
				'C'
				,'B'
				,'E'
				)
			AND PedExped.SeqFornecedor != 6
			THEN 'CROSS' || ' ' || PedExped.Fantasia
		WHEN PedExped.Descritivo LIKE ('%AUTOM%')
			OR PedExped.Descritivo LIKE ('%SORTIMENTO%')
			THEN 'PED AUTOMÁTICO'
		ELSE PedExped.Descritivo
		END AS NomePedido
	,b.NroCarga AS Carga_WMS
	,decode(f.FormaAbastecimento, 'C', 'CCEDL', 'I', 'CrossDocking', 'L', 'EDL', 'M', 'Centralizado') AS FormaAbastec
	,a.SeqProduto AS Codigo
	,c.DescCompleta AS Produto
	,d.Embalagem || '  ' || a.QtdEmbalagem AS Emb
	,fc5estoquetotal(a.SeqProduto, 6) / a.QtdEmbalagem AS Estoque_CD
	,fc5EstoqueDisponivel(a.SeqProduto, h.NroEmpresa) / a.QtdEmbalagem AS Estoque_Filial
	,e.MedVDiaGeral / a.QtdEmbalagem AS VdMed_Dia
	,CASE 
		WHEN fc5estoquedisponivel(a.SEQPRODUTO, h.NroEmpresa) = 0
			OR e.MEDVDIAGERAL = 0
			THEN 0
		ELSE fc5estoquedisponivel(a.SEQPRODUTO, h.NroEmpresa) / e.MedVDiaGeral
		END AS DiasEst
	,a.QtdPedida / a.QtdEmbalagem AS Qt_Solicitada
	,a.QtdAtendida / a.QtdEmbalagem AS Qt_Atendida
	,Nvl(Plt.Palete, 0) AS Palete
	,CASE 
		WHEN b.SituacaoPed IN (
				'L'
				,'D'
				)
			THEN 'Formação de Carga Pendente'
		WHEN b.SituacaoPed = 'R'
			THEN 'Roteirização'
		WHEN b.NroCarga IN (
				(
					SELECT LogImp.NomeArquivo
					FROM Mlo_LogImportacao LogImp
					WHERE (
							LogImp.NroEmpresa = 6
							OR LogImp.TipImportacao = 'P'
							)
						AND Nvl(LogImp.IndExcluiReproc, 'N') = 'N'
						AND LogImp.TipImportacao = 'E'
					)
				)
			THEN 'Carga com Critica no WMS'
		ELSE Nvl(Decode(g.StatusCarga, 'A', 'Separação Pendente', 'G', 'Separação Pendente', 'S', 'Em Separação', 'L', 'Liberada para Faturamento', 'C', 'Cancelada', 'F', 'Faturada', 'M', 'Carga em Manutenção', 'E', 'Carga Exportada WM', 'R', 'Carga em Reordenação de Entrega'), Decode(i.StatusCarga, 'A', 'Separação Pendente', 'G', 'Separação Pendente', 'S', 'Em Separação', 'L', 'Liberada para Faturamento', 'C', 'Cancelada', 'F', 'Faturada', 'M', 'Carga em Manutenção', 'E', 'Carga Exportada WM', 'R', 'Carga em Reordenação de Entrega'))
		END AS Situacao_Pedido
	,
	/*decode( b.TipPedido, 'C', 'Cotação', decode( b.SituacaoPed, 'D', 'Formação', 'L', 'Formação', 'P', 'Formação', 'R', 'Formação', 'S', 'Separação', 'C', 'Cancelado', 'F', 'Faturado',  'W', decode(b.IndSepConfTerc, 'S', 'Separação(Soft. Terceiro)', 'Separado' ),  b.SituacaoPed)) as Situacao_Pedido,*/
	Promoc.Promocao AS Promo
FROM Mad_PedVendaItem a
	,Mad_PedVenda b
	,Map_Produto c
	,Map_FamEmbalagem d
	,Mrlv_ProdutoEmpresa e
	,Map_FamDivisao f
	,Mlo_CargaExped g
	,Ge_Empresa h
	,Mrl_CargaExped i
	,(
		SELECT a.SeqProduto
			,CASE 
				WHEN c.PmtDecimal = 'S'
					AND a.QtdEmbalagem = 1
					THEN 1000
				ELSE a.PaleteLastro * a.PaleteAltura
				END AS Palete
			,a.QtdEmbalagem /*,
    c.PmtDecimal*/
		FROM Mlo_ProdEspEndereco a
			,Map_Produto b
			,Map_Familia c
		WHERE
			/*Joins*/
			a.SeqProduto = b.SeqProduto
			AND b.SeqFamilia = c.SeqFamilia
			/*Filtros*/
			AND NroEmpresa = 6
			AND EspecieEndereco = 'P'
		) Plt
	,(
		SELECT PedSuprim.DtaEmissao
			,PedItem.NroEmpDestino
			,Lote.SeqFornecPrincipal AS SeqFornecedor
			,PedItem.NroPedidoSuprim
			,PedItem.NroPedVenda
			,PedItem.SeqProduto
			,Lote.TipoLote
			,Lote.Descritivo
			,ge.Fantasia AS Fantasia
		FROM Msu_PsItemExpedido PedItem
			,Msu_PedidoSuprim PedSuprim
			,Mac_GerCompra Lote
			,Ge_Pessoa ge
		WHERE
			/*Joins*/
			PedSuprim.NroPedidoSuprim = PedItem.NroPedidoSuprim
			AND PedSuprim.NroEmpresa = PedItem.NroEmpresa
			AND PedSuprim.SeqGerCompra = Lote.SeqGerCompra(+)
			AND Lote.SeqFornecPrincipal = ge.SeqPessoa(+)
			/*Filtros*/
			AND PedItem.NroEmpresa = 6
			AND PedItem.NroEmpresaPedVenda = 6
		) PedExped
	,(
		SELECT DISTINCT PromoI.Nroempresa
			,PromoI.SeqProduto
			,1 AS Promocao
		FROM Mrl_PromocaoItem PromoI
			,Mrl_Promocao Promo
		WHERE Promo.NroEmpresa = PromoI.NroEmpresa
			AND Promo.SeqPromocao = PromoI.SeqPromocao
			AND Promo.Promocao NOT LIKE ('%PVPS%')
			AND PromoI.STATUS = 'A'
			/*and PromoI.NroEmpresa Not in (5,6,27,28,998,999)*/
			AND (
				PromoI.DtaInicioProm BETWEEN trunc(sysdate) - 365
					AND trunc(sysdate) + 5
				AND PromoI.DtaFimProm > trunc(sysdate) - 1
				)
		) Promoc
WHERE
	/*Joins*/
	a.NroEmpresa = b.NroEmpresa
	AND a.NroPedVenda = b.NroPedVenda
	AND a.SeqProduto = c.SeqProduto
	AND b.SeqPessoa = h.SeqPessoa
	AND d.SeqFamilia = c.SeqFamilia
	AND d.QtdEmbalagem = a.QtdEmbalagem
	AND e.NroEmpresa = h.NroEmpresa
	AND e.SeqProduto = a.SeqProduto
	AND f.SeqFamilia = c.SeqFamilia
	AND f.NroDivisao = 1
	AND g.NroEmpresa(+) = b.NroEmpresa
	AND g.NroCarga(+) = b.NroCarga
	AND i.NroEmpresa(+) = b.NroEmpresa
	AND i.NroCarga(+) = b.NroCarga
	AND Plt.SeqProduto(+) = a.SeqProduto
	AND Plt.QtdEmbalagem(+) = a.QtdEmbalagem
	AND PedExped.NroPedVenda(+) = a.NroPedVenda
	AND PedExped.NroEmpDestino(+) = h.NroEmpresa
	AND PedExped.SeqProduto(+) = a.SeqProduto
	AND b.NroEmpresa = 6
	AND Promoc.NroEmpresa(+) = h.NroEmpresa
	AND Promoc.SeqProduto(+) = a.SeqProduto
	/*Filtros*/
	AND Nvl(a.StatusItem, 'V') != 'C'
	AND b.SituacaoPed IN (
  		 'D'
		,'L'
		,'R'
		,'P'
		,'S'
		)
	AND b.OrigemPedido = 'T'
	/*and Nvl(g.CodDeposSepar,'01') != '02'*/
	AND h.Matriz = 6
/*and b.NroPedVenda = 1081401*/
/*and b.CodGeralOper in (853)*/

</sql>
