  <step>
    <name>Calcula Projeção</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>BI 238 DW</connection>
    <sql>WITH calculo_base AS
  (
    SELECT
      EXTRACT(DAY FROM CURRENT_DATE - 1)                                                     AS dia_atual,
      EXTRACT(DAY FROM (DATE_TRUNC('month', CURRENT_DATE - 1 ) + INTERVAL '1 month - 1 day')) AS total_dias_mes )
SELECT
  CURRENT_DATE - 1 AS data_atual                                                                   ,
  dia_atual                                                                                    ,
  total_dias_mes                                                                               ,
  ROUND((dia_atual::NUMERIC       * 100 / total_dias_mes::NUMERIC), 2) AS percentual_percorrido,
  100 - ROUND((dia_atual::NUMERIC * 100 / total_dias_mes::NUMERIC), 2) AS percentual_faltante
FROM
  calculo_base

/*
WITH serie_dias AS (
    SELECT generate_series(1, 31) AS dia
),
dias_mes AS (
    SELECT 
        EXTRACT(DAY FROM (DATE_TRUNC('month', CURRENT_DATE) + INTERVAL '1 month - 1 day'))::INTEGER AS total_dias_mes
)
SELECT 
    s.dia,
    d.total_dias_mes,
    CASE 
        WHEN s.dia &lt;= d.total_dias_mes THEN 'Dia Válido'
        ELSE 'Dia Inválido'
    END AS status_dia,
    CASE 
        WHEN s.dia &lt;= d.total_dias_mes THEN 
            ROUND((s.dia::NUMERIC / d.total_dias_mes::NUMERIC) * 100, 2)
        ELSE NULL
    END AS percentual_percorrido,
    CASE 
        WHEN s.dia &lt;= d.total_dias_mes THEN 
            ROUND(((d.total_dias_mes::NUMERIC - s.dia::NUMERIC) / d.total_dias_mes::NUMERIC) * 100, 2)
        ELSE NULL
    END AS percentual_faltante
FROM 
    serie_dias s
CROSS JOIN 
    dias_mes d
ORDER BY 
    s.dia;
*/</sql>
