  <step>
    <name>MRL_METAVENDA</name>
    <type>TableInput</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>SELECT 
   A.DTAINICIO
  ,A.NROEMPRESA
  ,SUM(A.METAVENDA) AS METAVENDA
    ,SUM (DISTINCT C.META) AS META_IFOOD
FROM MRL_METAVENDA A
INNER JOIN GE_EMPRESA B ON A.NROEMPRESA = B.NROEMPRESA
LEFT JOIN  META_REGIONAL_IFOOD C  ON A.NROEMPRESA = C.NROEMPRESA
  AND EXTRACT(YEAR FROM A.DTAINICIO) >= 2024
GROUP BY 
     A.DTAINICIO
  ,A.NROEMPRESA

union all 

SELECT 
TO_DATE('20251101', 'YYYYMMDD') as DTAINICIO ,
42 AS NROEMPRESA, 
2800000 AS METAVENDA ,
0 AS META_IFOOD
FROM DUAL

ORDER BY 1 desc,2


/*
SELECT 
	 A.DTAINICIO
	,A.NROEMPRESA
	,SUM(A.METAVENDA) AS METAVENDA
    ,SUM (DISTINCT C.META) AS META_IFOOD
FROM MRL_METAVENDA A
INNER JOIN GE_EMPRESA B ON A.NROEMPRESA = B.NROEMPRESA
LEFT JOIN  META_REGIONAL_IFOOD C  ON A.NROEMPRESA = C.NROEMPRESA
  AND EXTRACT(YEAR FROM A.DTAINICIO) >= 2024
GROUP BY 
     A.DTAINICIO
  ,A.NROEMPRESA
ORDER BY A.DTAINICIO DESC
*/</sql>
