  TIPOENTIDADEDB,
  CODENTIDADEDB,
  CENTROCUSTODB,
  CONTACR,
  TIPOENTIDADECR,
  CODENTIDADECR,
  CENTROCUSTOCR,
  CASE WHEN CONTADB &lt;&gt; 0 THEN (VALOR * -1) ELSE (VALOR) END AS VALOR,
  CASE WHEN CONTADB &lt;&gt; 0 THEN CONTADB ELSE CONTACR END AS XX_CONTA,
  NROARQUIVODOCTO,
  HISTORICO,
  ORIGEM,
  IMPORTADODE,
  VALORMOEDA,
  LINKEXTERNO,
  DTACONCILIOU,
  USUCONCILIOU,
  DTACANCELOU,
  USUCANCELOU,
  IDENTTABELA,
  USUALTERACAO,
  DTAALTERACAO,
  LANCTOALTERADO,
  PROCESSOCTB,
  NRODOCUMENTO,
  CODHISTORICO,
  NROPLANILHA,
  LANCTOREVERTIDO,
  PROCESSOCTB_ANTIGO,
  CODIGOFINANCEIRO,
  HISTORICOPADRAO
FROM CONSINCO.CTV_LANCAMENTO
WHERE 
  DTACANCELOU IS NULL
  AND (SUBSTR(TO_CHAR(CONTADB), 1, 1) = '3' OR SUBSTR(TO_CHAR(CONTACR), 1, 1) = '3')
  --AND DTALANCAMENTO >= DATE '2021-01-01'  -- ✅ Otimização do filtro de data
  AND DTALANCAMENTO >= DATE '2025-01-01'  -- ✅ Otimização do filtro de data
  AND NROEMPRESA IN (6, 901, 998, 500, 501)
  AND LOTE &lt;&gt; ?
</sql>
