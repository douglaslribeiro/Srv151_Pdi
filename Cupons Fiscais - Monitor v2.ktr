  <step>
    <name>MFL_CUPOMFISCAL</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>WITH OPERADORES AS
  (
    SELECT DISTINCT
      NOMERAZAO   ,
      SEQOPERADOR ,
      CODUSUARIO
    FROM
      CONSINCO.MRLV_OPERADORES )
, DESCONTOS AS (      
SELECT
  A.DTAHORAMOVTO  ,
  A.NROEMPRESA    ,
  A.NROCHECKOUT   ,
  A.NUMERONF      ,
  A.SEQITEMDF     ,
  A.SEQOPERADOR   ,
  A.SEQSUPERVISOR ,
  A.OBSERVACAO    ,
  A.CODPRODUTO    ,
  A.CODACESSO     ,
  A.STATUSITEM    ,
  A.QUANTIDADE    ,
  A.QTDEMBALAGEM  ,
  A.VLRITEM       ,
  A.VLRDESCONTO   ,
  A.VLRTOTOUTRA   ,
  A.BASCALCICMS
FROM
  MFL_CUPOMFISCAL A
where (A.DTAHORAMOVTO >= '01-JAN-2026' AND A.DTAHORAMOVTO &lt; '10-MAR-2027')
AND A.VLRDESCONTO > ?
AND A.SEQPROMOCPDV IS NOT NULL
-- AND A.SEQOPERADOR &lt;&gt; A.SEQSUPERVISOR ,
--
-- and A.NROEMPRESA = 1
--
)
SELECT A.* , B.NOMERAZAO AS OPERADOR , C.NOMERAZAO AS SUPERVISOR FROM DESCONTOS A
LEFT JOIN OPERADORES B ON A.SEQOPERADOR   = B.SEQOPERADOR
LEFT JOIN OPERADORES C ON A.SEQSUPERVISOR = C.SEQOPERADOR
</sql>
    <limit>0</limit>
