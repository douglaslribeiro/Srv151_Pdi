    </partitioning>
    <connection>CONSINCO</connection>
    <sql>SELECT
  SEQGERCOMPRA      ,
  SEQCOMPRADOR      ,
  SITUACAOLOTE      ,
  DTAHORINCLUSAO    ,
  USUINCLUSAO       ,
  NROPEDIDOSUPRIM   ,
  NROEMPRESA        ,
  DTAAPROVACAO      ,
  USUAPROVACAO      ,
  NROEMPDESTINO     ,
  SEQPRODUTO        ,
  QTDCANCELADA      ,
  DTAHORCANCELAMENTO,
  USUCANCELAMENTO   ,
  NROPEDVENDA       ,
  NUMERONF          ,
  SERIENF           ,
  DTAROTEIRIZACAO   ,
  DTAGERACAOCARGA   ,
  DTAGERACAONF      ,
  NROCARGA          ,
  SITUACAOPED       ,
  CODDEPOSSEPAR     ,
  NROBOX            ,
  DTAHORGERACAO     ,
  DTAHORGERAPALETE  ,
  STATUSCARGA       ,
  QTDEMBALAGEM      ,
  QTDEMBSOLICITADA  ,
  QTDEMBSEPARADA    ,
  VLRITEMUNITARIO   ,
  SEQLOTE           ,
  CODPRODUTIVO      ,
  DTAHORLANCAMENTO  ,
  USULANCAMENTO     ,
  TEMPO             ,
  PESO              ,
  METRAGEMCUBICA    ,
  DTAHORINICIO      ,
  DTAHORFIM         ,
  SEQENDERECO       ,
  DTAVALIDADE       ,
  DTARECEBIMENTO    ,
  DTAFABRICACAO     ,
  CODRUA            ,
  TIPESPECIE        ,
  DESCESPECIE
FROM
  qview_acomp_abastecimento
WHERE
  dtahorinclusao >= TRUNC(SYSDATE) - 17 AND dtahorinclusao &lt; TRUNC(SYSDATE) - 1

/*
WHERE
--  dtahorinclusao >= ADD_MONTHS(TRUNC(SYSDATE), ?)
  trunc(dtahorinclusao) >= trunc(sysdate)-14
*/</sql>
