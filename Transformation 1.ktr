  <step>
    <name>mfl_doctofiscal</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>select
  a.* ,
  b.*
from
  mfl_doctofiscal a
inner join
  mfl_dfitem b
on
  a.seqnf = b.seqnf
and a.nroempresa in( 600,
                     601 )
and a.dtamovimento >= TO_DATE('01-08-2025', 'DD-MM-YYYY')
order by
  a.dtamovimento
  
  </sql>
    <limit>0</limit>
