    <connection>BI 238</connection>
    <sql>SELECT
  loggingdate
, loggingphase
, pipelinename
, pipelinefilename
, pipelinestart
, pipelineend
, pipelinelogchannelid
, parentlogchannelid
, pipelinelogging
, pipelineerrorcount
, pipelinestatusdescription
, transformname
, transformcopynr
, transformstatusdescription
, transformlogchannelid
, transformloggingtext
, transformlinesread
, transformlineswritten
, transformlinesinput
, transformlinesoutput
, transformlinesupdated
, transformlinesrejected
, transformerrors
, transformstart
, transformend
, transformduration
, ip_servidor
FROM logs.transformations_hop
WHERE loggingdate >= CURRENT_TIMESTAMP - INTERVAL '4 days'</sql>
