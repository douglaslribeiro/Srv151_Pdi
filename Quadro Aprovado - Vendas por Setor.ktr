  <step>
    <name>Vendas p Setor</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>BI 238 DW</connection>
    <sql>with temp_01 as
  (
    SELECT
      extract(month from a.dtmovimento) as Mes,
      extract(year from a.dtmovimento)  as Ano,
      nroempresa                              ,
      b.departamento                          ,
      case when b.departamento = 'MERCEARIA' then b.departamento else b.secao  end secao,
      vlrvendaliq
    FROM
      "public".fat_venda a
    inner join
      public.dim_produto b
    on
      a.seqproduto                        = b.seqproduto
    and extract(month from a.dtmovimento) = 11
    and extract(year from a.dtmovimento)  = 2025 )
select
  nroempresa,
  departamento  ,
  secao     ,
  sum(vlrvendaliq ) vlrvendaliq
from
  temp_01
group by
  nroempresa,
  departamento,
  secao</sql>
