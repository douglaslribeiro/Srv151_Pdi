    <sql>with temp_01 as
  (
    SELECT
      extract(month from a.dtmovimento) as Mes,
      extract(year from a.dtmovimento)  as Ano,
      nroempresa                              ,
      b.departamento                          ,
      case when b.departamento = 'MERCEARIA' then b.departamento else b.secao  end secao,
      vlrvendaliq
    FROM
      "public".fat_venda a
    inner join
      public.dim_produto b
    on
      a.seqproduto                        = b.seqproduto
    and extract(month from a.dtmovimento) = 03
    and extract(year from a.dtmovimento)  = 2026 )
select
  a.nroempresa,
  a.departamento  ,
  a.secao     ,
  b.regional,
  sum(vlrvendaliq ) vlrvendaliq
from
  temp_01 a
left join public.dim_loja b on a.nroempresa = b.nroempresa  
group by
  a.nroempresa,
  a.departamento,
  a.secao,
  b.regional 

/*

