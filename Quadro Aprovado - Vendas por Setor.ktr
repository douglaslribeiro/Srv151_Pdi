  <step>
    <name>Quadro Ativo</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>BI 238 DW</connection>
    <sql>with temp_01 as
  (
    SELECT
      idempresa ,
      setor     ,
      count(*) qtd
    FROM
      public.tmp_funcionarios
    where
      status = 'ATIVO'
    group by
      idempresa ,
      setor
    order by
      1,
      2 )
select
  idempresa,
  case when setor = 'HORTIFRUTI' then 'FLV' else setor end as setor_ativo,
  qtd as qtd_ativo
from
  temp_01</sql>
