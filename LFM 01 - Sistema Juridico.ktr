    <connection>CONSINCO 242</connection>
    <sql>SELECT 
	 ABERTOQUITADO
	,APPORIGEM
	,CODESPECIE
	,CODESPECIE DESCRICAO
	,DTAALTERACAO
	,DTAEMISSAO
	,DTAMOVIMENTO
	,DTAPROGRAMADA
	,DTAQUITACAO
	,DTAVENCIMENTO
	,DTAVENCIMENTOORIG
	,NROBANCO
	,NRODOCUMENTO
	,NROEMPRESA
	,NROPARCELA
	,OBRIGDIREITO
	,OBSERVACAO
	,ORIGEMDOC
	,PERCADMINISTRACAO
	,PROVENIENCIA
	,QTDPARCELA
	,SEQAGENCIA
	,SEQDEPOSITARIO
	,SEQPESSOA
	,SEQPESSOANOTA
	,SEQTITULO
	,SERIEDOC
	,SITUACAO
	,TIPOESPECIE
	,TIPOVENCORIGINAL
	,USUALTERACAO
	,VLRADMINISTRACAO
	,VLRNOMINAL
	,CASE WHEN OBRIGDIREITO = 'O' THEN VLRORIGINAL * -1 ELSE VLRORIGINAL END VLRORIGINAL
	,CASE WHEN OBRIGDIREITO = 'O' THEN VLRPAGO     * -1 ELSE VLRPAGO     END VLRPAGO
	,NROTITULO
FROM FI_TITULO
WHERE CODESPECIE IN (
		 'JURIDI'
		,'DEPOSI'
		,'DEPOSR'
		)</sql>
