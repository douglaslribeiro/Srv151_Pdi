  <step>
    <name>Audiências</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>LFM</connection>
    <sql>select   
                                               dba.propro.pronumero as 'Processo',
                                               dba.provar.varcodigo as 'Juízo',
                                               dba.proaco.acodescri as 'Tipo de ação',
                                               dba.propro.proautdes as 'Autor',
                                               dba.propro.proreudes as 'Réu',
                                               convert(char(10), dba.proand.anddatass, 103) as 'Data Audiência',
                                               case dba.proand.andtabela when 3 then convert(char(5) , dba.proand.andhorass, 108) else '---' end as 'Hora Audiência',
                                               dba.protan.tandescri as 'Tipo Audiência',
                                               case dba.proand.andtabela
                                                               when 3 then
                                                                               case dba.proand.andrespos
                                                                                              when 1 then 'Presencial'
                                                                                              when 2 then 'Virtual' + case isnull(andlinkss, '') when '' then 'Não informado' else andlinkss end
                                                                                              when 3 then 'Híbrida' + case isnull(andlinkss, '') when '' then 'Não informado' else andlinkss end
                                                                               end
                                                               else
                                                                               '---'
                                               end as 'Local',
                                               isnull((select dba.digcli.cliadvsig from dba.digcli where dba.digcli.clisequen = dba.proand.andadvseq ), '---') as 'Advogado designado',
                                               dba.proand.anddescri as 'Descrição'
                from      dba.proand
                                               inner join dba.propro on dba.propro.prosequen = dba.proand.andproseq and dba.propro.protiposs = 1
                                               inner join dba.provar on dba.provar.varsequen = dba.propro.provarseq
                                               inner join dba.proaco on dba.proaco.acosequen = dba.propro.proacoseq
                                               left join  dba.protan on dba.protan.tansequen = dba.proand.andtanseq
                where dba.proand.andtabela = 3 </sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
