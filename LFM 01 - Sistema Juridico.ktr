  <step>
    <name>proval - Valores dos Processos</name>
    <type>TableInput</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>LFM</connection>
    <sql>SELECT 
     valsequen
    ,valdatass
	,valproseq
	,valmoeseq
	,valtiposs
	,b.tvacodigo
	,valvalors
	,valdatatu
	,valvalatu
	,valtiprea
	,case when valtiposs = 301 then valdatass else null end valdatass
	,valvalmul
	,valcliseq
	,valvaljur
	,valvalbas
	,valadvseq
	,valnumman
	,valobserv
FROM LFM_SUAL.dba.proval a
INNER JOIN dba.protva b ON a.valtiposs = b.tvasequen --and a.valproseq = 116301
order by a.valproseq
	-- where valproseq = 81701



/*
SELECT valsequen, valproseq, valmoeseq, valtiposs, b.tvacodigo ,  valvalors, valdatatu, valvalatu, valtiprea, valdatass, valvalmul, valcliseq, valvaljur, valvalbas, valadvseq, valnumman, valobserv
FROM LFM_SUAL.dba.proval a inner join dba.protva b on a.valtiposs = b.tvasequen 
--where valproseq = 81701

*/</sql>
