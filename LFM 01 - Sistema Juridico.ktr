    <connection>LFM</connection>
    <sql>Select
  dba.propro.prosequen ,
  dba.proand.andcaddat ,
  dba.protan.tandescri 
from
  dba.proand,
  dba.protan,
  dba.propro
Where
  dba.proand.andproseq   = dba.propro.prosequen
and dba.proand.andta1seq = dba.protan.tansequen
and dba.proand.andtabela = 1
and dba.proand.andencerr = 1</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
