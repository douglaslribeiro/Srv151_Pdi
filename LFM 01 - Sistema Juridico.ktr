    <connection>LFM</connection>
    <sql>SELECT
  dba.proand.andproseq,
  dba.proand.andsequen,
  dba.proand.anddescri,
  dba.proand.andtanseq,
  dba.proand.andvalors,
  dba.proand.andcliseq,
  dba.protan.tandescri,
  dba.proris.risdescri,
  dba.digcli.clidescri
FROM
  dba.proand
inner join
  dba.digcli
on
  dba.digcli.clisequen = dba.proand.andcliseq
inner join
  dba.protan
on
  dba.protan.tansequen = dba.proand.andtanseq
inner join
  dba.proris
on
  dba.proris.rissequen = dba.proand.andrisseq
WHERE
  dba.proand.andtabela = 20</sql>
