  <step>
    <name>MLFV_NOTAFISCAL</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>WITH NOTAS_FISCAIS AS (
    SELECT 
        A.NUMERONF,
        A.SEQPESSOA,
        A.NROEMPRESA,
        B.NOMEREDUZIDO AS EMPRESA,
        A.TIPNOTAFISCAL,
        CAST(A.DTAEMISSAO AS DATE) AS DTAEMISSAO,
        CAST(A.DTAENTRADA AS DATE) AS DTAENTRADA,
        A.SEQNF,
        A.CODGERALOPER,
        C.DESCRICAO AS OPERACAO,
        --A.VLRTOTALNF,
        A.VLRBASEIBSUF AS VLRTOTALNF,
        D.NOMERAZAO || ' / ' || D.SEQPESSOA AS FORNECEDOR,
        A.LINKERP
    --FROM MLFV_NOTAFISCAL A
    FROM MLF_NOTAFISCAL A
    INNER JOIN GE_EMPRESA B ON A.NROEMPRESA = B.NROEMPRESA
    INNER JOIN MAX_CODGERALOPER C ON A.CODGERALOPER = C.CODGERALOPER
    INNER JOIN GE_PESSOA D ON A.SEQPESSOA = D.SEQPESSOA
    WHERE A.SEQPESSOA NOT IN (1,10,12,13,14,15,16,17,18,19,2,20,21,22,25,27,3,32,33,35,36,37,4,6,64033,7,8,9,34,38,41)
      AND A.DTAEMISSAO BETWEEN '01-JAN-2025' AND '31-dec-2030'-->= DATE '2026-03-01'
      AND A.TIPNOTAFISCAL = 'E'
      AND A.NROEMPRESA = 998
      AND A.CODGERALOPER = 14
      --
      -- AND A.NUMERONF IN (25269, 25270)
      -- AND A.NUMERONF = 18598
      --
)
SELECT 
    NF.NUMERONF,
    NF.SEQPESSOA,
    NF.FORNECEDOR,
    NF.NROEMPRESA,
    NF.EMPRESA,
    NF.TIPNOTAFISCAL,
    NF.DTAEMISSAO,
    NF.DTAENTRADA,
    NF.SEQNF,
    NF.CODGERALOPER,
    NF.OPERACAO,
    NF.VLRTOTALNF,
    ITEM.SEQPRODUTO,
    ITEM.SEQITEMNF,
    ITEM.QUANTIDADE,
    ITEM.VLRITEM,
    PROD.DESCCOMPLETA AS PRODUTO,
    NF.LINKERP
FROM NOTAS_FISCAIS NF
INNER JOIN MLF_NFITEM ITEM ON NF.SEQNF = ITEM.SEQNF
INNER JOIN MAP_PRODUTO PROD ON ITEM.SEQPRODUTO = PROD.SEQPRODUTO
ORDER BY NF.SEQNF, ITEM.SEQITEMNF</sql>
