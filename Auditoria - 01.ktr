    <connection>CONSINCO</connection>
    <sql>WITH LINKREP AS
  (
    SELECT DISTINCT
      LINKERP
    FROM
      MLF_NOTAFISCAL
    WHERE
      DTAEMISSAO >= '01-JAN-2025' ) ,
  SEQTITULO_LINKERP AS
  (
    SELECT
      A.SEQTITULO,
      B.LINKERP,
      A.DTAQUITACAO ,
      A.ABERTOQUITADO,
      A.OBRIGDIREITO 
      --, A.SEQPESSOANOTA , A.SEQPESSOA, A.NROEMPRESA, A.DTAEMISSAO, A.DTAPROGRAMADA,  A.ABERTOQUITADO , A.USUALTERACAO, A.SITUACAO , A.OBSERVACAO  , A.NROTITULO, A.CODESPECIE, A.NRODOCUMENTO, A.NROPARCELA , A.QTDPARCELA, A.VLRORIGINAL , A.VLRNOMINAL, A.VLRPAGO
    FROM
      FI_TITULO A
    INNER JOIN
      LINKREP B
    ON
      A.LINKERP   = B.LINKERP
    --AND ABERTOQUITADO = 'Q'
    --AND SEQTITULO = 174167766
    )
SELECT
  D.OBSERVACAO        ,
  D.DTAOPERACAO       ,  
  D.DTACONTABILIZA    ,  
  C.DTAQUITACAO       ,
  C.ABERTOQUITADO     ,
  C.OBRIGDIREITO      ,
  D.VLROPERACAO       ,  
  D.USUALTERACAO      ,  
  D.DTAALTERACAO      ,  
  D.DTAHORAALTERACAO  ,
  C.SEQTITULO         , 
  C.LINKERP           ,
  D.SEQTITULO         ,
  D.NROPROCESSO       ,
  D.SEQTITOPERACAO    ,
--  D.SEQLANCTO         ,
  D.CODOPERACAO       ,
  D.COLOPERACAO1        
/*
  D.NRODOCUMENTO      ,
  D.ANOTACAO          ,
  D.TIPOASSUMIDO      ,
  D.SEQCTACORRENTE    ,
  D.DTACONCILIACAO    ,
  D.USUCONCILIOU      ,
  D.SITUACAO          ,
  D.DTAQUITACAOANT    ,
  D.OPCANCELADA       ,
  D.USUCANCELOU       ,
  D.DTACANCELOU       ,
  D.JUSTCANCEL        ,
  D.CODESPECIEANT     ,
  D.NROEMPRCTAPARTIDA ,
  D.SEQTITDESCONTO    ,
  D.ORIGEM            ,
  D.DTAHORACANCELOU   ,
  D.USUARIOSO         ,
  D.IP                ,
  D.MAQUINA           ,
  D.MODULO            ,
  D.INDESOCIAL        ,
  D.SEQDEPOSITARIO    ,
  D.SEQEXPFLUXOCAIXA
*/
FROM
  SEQTITULO_LINKERP C
INNER JOIN
  FI_TITOPERACAO D
ON
  C.SEQTITULO = D.SEQTITULO
ORDER BY D.DTAHORAALTERACAO 

</sql>
