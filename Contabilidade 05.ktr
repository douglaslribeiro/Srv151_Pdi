  <step>
    <name>FINANCEIRO - FI_CONTABILIZACAO</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>SELECT DISTINCT
  A.NROPROCESSO
, A.CODOPERACAO
, A.NROEMPRESA
, A.FILIAL
, A.DTACONTABILIZA
, CASE WHEN A.DEBCRED = 'D' THEN (A.VALOR * -1) ELSE A.VALOR END VALOR
, A.CTACONTABIL
, A.HISTORICO
, A.CODESPECIE
, B.DESCRICAO AS "DESCRICAO_ESPECIE"
FROM CONSINCO.FI_CONTABILIZACAO A
INNER JOIN CONSINCO.FI_ESPECIE B ON A.CODESPECIE = B.CODESPECIE
AND
  (TRUNC(A.DTACONTABILIZA) >= '01-JAN-22')
AND
    (A.OPCANCELADA IS NULL OR A.OPCANCELADA = 'N')
AND
    SUBSTR(A.CTACONTABIL,1,1) = '3' 
AND
	A.NROEMPRESA IN (6,998)
</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
