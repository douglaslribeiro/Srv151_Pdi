  <step>
    <name>Local do Estoque</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 242</connection>
    <sql>SELECT 
      NROEMPRESA
	, SEQPRODUTO
	, ESTOQUE
    , SEQLOCAL
FROM MRL_PRODLOCAL a
WHERE ESTOQUE &lt;&gt; 0
AND       (
			a.NROEMPRESA BETWEEN 1 AND 99 AND a.NROEMPRESA NOT IN (
				   5
				, 28
				, 31
				)
			)
</sql>
    <limit>0</limit>
    <lookup/>
