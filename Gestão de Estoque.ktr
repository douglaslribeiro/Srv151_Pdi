  <step>
    <name>MRL_LOCAL</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 242</connection>
    <sql>SELECT 
      SEQLOCAL
	, NROEMPRESA
	, "LOCAL"
	, CASE 
		WHEN TIPLOCAL = 'L' THEN 'Loja'
		WHEN TIPLOCAL = 'O' THEN 'Outro'
		WHEN TIPLOCAL = 'D' THEN 'Depósito'
		WHEN TIPLOCAL = 'T' THEN 'Troca'
		WHEN TIPLOCAL = 'E' THEN 'Terceiro'
		END 
		TIPLOCAL
	, INDPADRAOENT
	, INDPADRAOSAIDA
	, PERMTRANSFENTRADA
	, PERMTRANSSAIDA
	, STATUS
	, DTAALTERACAO
	, USUALTERACAO
	, NROEMPMEDIAVENDA
	, DESCPONTOIMP
	, FINALIDADEESTOQUE
	, INDCONTMOVAVARIACOML
	, INDCARGANFLOCUS
	, INDCARGAMOVINTERNALOCUSENT
	, INDCARGAMOVINTERNALOCUSSAIDA
	, NROEMPRESAREF
	, NROBASEEXPORTACAO
	, INDCOMPARESTOQUEWMS
