    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>/* 29.10- Subtrai QTDRESERVADAVDA do ESTQLOJA */
WITH TEMP_01 AS
  (
    SELECT
      CASE
      WHEN
        (a.ESTQLOJA       = 0
        OR a.MEDVDIAGERAL = 0)
      THEN
        0
      ELSE
        round((a.ESTQLOJA - a.QTDRESERVADAVDA )/ a.MEDVDIAGERAL, 1)
      END Em_Dias ,
      a.*
    FROM
      mrlv_produtoempresa a
    --WHERE (a.NROEMPRESA BETWEEN 1 AND 99 AND a.NROEMPRESA NOT IN ( 5 , 28 ,31) ) 
  )
SELECT
  FC_CMDIACUSTOBRUTO(b.SEQPRODUTO, b.NROEMPRESA) CUSTO_BRUTO_UNITARIO, 
  NVL(ESTQLOJA, 0) + NVL(ESTQDEPOSITO, 0) + NVL(ESTQTROCA, 0) + NVL(ESTQTERCEIRO, 0) + NVL(ESTQOUTRO, 0)                                                    AS ESTOQUE_SOMA       ,
  NVL(c.QTDESTQINICIAL + c.QTDENTRADA - c.QTDSAIDA, NVL(ESTQLOJA, 0) + NVL(ESTQDEPOSITO, 0) + NVL(ESTQTROCA, 0) + NVL(ESTQTERCEIRO, 0) + NVL(ESTQOUTRO, 0)) AS ESTOQUE_FECHAMENTO ,
  B.*
FROM
  TEMP_01 B
LEFT JOIN
  mrl_custodia c
ON
  b.nroempresa        = c.nroempresa
AND b.seqproduto      = c.SEQPRODUTO
AND c.DTAENTRADASAIDA = trunc(sysdate) - 1
/*
and b.seqproduto NOT IN
( 17977,
                        12651,
                        72600,
                        12654,
						10818,
						12651,
						12652,
						12653,
						12654,
						12655,
						12657,
						12661,
						58855,
						17977,
                        12655,
                        17911,
                        12653,
                        10818,
                        12657,
                        12652,
                        62985,
                        12661 )
*/</sql>
