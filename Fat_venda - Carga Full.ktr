      <value-meta>
        <type>Number</type>
        <storagetype>normal</storagetype>
        <name>QTDEMBALAGEM</name>
        <length>12</length>
        <precision>6</precision>
        <origin>fat_venda (CONSINCO)</origin>
        <comments>QTDEMBALAGEM</comments>
        <conversion_Mask>####0.0#########;-####0.0#########</conversion_Mask>
        <decimal_symbol>.</decimal_symbol>
