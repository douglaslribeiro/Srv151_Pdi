    <connection>CONSINCO 242</connection>
    <sql>SELECT 
      PR1.SEQPROMOCAO
	, GP1.SEQGRUPOPROMOC
	, V.DTAVDA AS DTMOVIMENTO
	, V.NROEMPRESA
	, V.NROSEGMENTO
	, A.SEQPRODUTO
	, K.QTDEMBALAGEM AS QTDEMBALAGEM
	, SUM(ROUND((V.QTDITEM - V.QTDDEVOLITEM) / K.QTDEMBALAGEM, 6)) AS QUANTIDADE
	, COUNT(DISTINCT V.ROWIDDOCTO) AS NRODOCTOS
	, COUNT(DISTINCT V.SEQPESSOA) AS NROCLIENTES
	, COUNT(DISTINCT V.SEQPRODUTO) AS NROITENS
	, SUM(((ROUND(V.VLRITEM, 2)) - (ROUND(V.VLRDEVOLITEM, 2) - (0))) + NVL(VLREMBDESCRESSARCST, 0) - NVL(VLREMBDESCRESSARCSTDEVOL, 0)) AS VLRVENDALIQ
	, SUM(COALESCE(V.VLRVENDAPROMOC - CASE 
				WHEN V.VLRVENDAPROMOC > 0
					THEN NVL(VLRDESCITEM, 0)
				ELSE 0
				END, (DECODE(NVL(FMRL_SEQPROMOCPROD(A.SEQPRODUTO, Y.NROEMPRESA, NVL(V.DTANFREF, Y.DTAENTRADASAIDA), V.NROSEGMENTO, NULL), 0), 0, 0, (ROUND(V.VLRITEM, 2)) - (ROUND(V.VLRDEVOLITEM, 2) - (0)))))) AS VLRVENDAPROMOC
	, ROUND(SUM(FC5_ABCDISTRIBLUCRATIVIDADE('L', 'L', 'N', V.VLRITEM, 'N', V.VLRICMSST, V.VLRFCPST, V.VLRICMSSTEMPORIG, E.UF, V.UFPESSOA, 'N', 0, 'N', V.VLRIPIITEM, V.VLRIPIDEVOLITEM, 'N', V.VLRDESCFORANF, Y.CMDIAVLRNF - 0, Y.CMDIAIPI, NVL(Y.CMDIACREDPIS, 0), NVL(Y.CMDIACREDCOFINS, 0), Y.CMDIAICMSST, Y.CMDIADESPNF, Y.CMDIADESPFORANF, Y.CMDIADCTOFORANF, 'S', A.PROPQTDPRODUTOBASE, V.QTDITEM, V.VLREMBDESCRESSARCST, V.ACMCOMPRAVENDA, V.PISITEM, V.COFINSITEM, DECODE(V.TIPCGO, 'S', Y.QTDVDA, NVL(Y.QTDDEVOL, Y.QTDVDA)), (DECODE(V.TIPCGO, 'S', Y.VLRIMPOSTOVDA - NVL(Y.VLRIPIVDA, 0), NVL(((Y.VLRIMPOSTODEVOL / DECODE(NVL(Y.QTDDEVOL, 0), 0, 1, Y.QTDDEVOL)) * V.QTDDEVOLITEM) - NVL(V.VLRIPIDEVOLITEM, 0), Y.VLRIMPOSTOVDA - NVL(Y.VLRIPIVDA, 0)))), 'N', V.VLRDESPOPERACIONALITEM, Y.VLRDESPESAVDA, 'N', NVL(Y.VLRVERBAVDAACR, 0), V.QTDVERBAVDA, V.VLRVERBAVDA, 'N', NVL(V.VLRTOTCOMISSAOITEM, 0), V.VLRDEVOLITEM, VLRDEVOLICMSST, V.DVLRFCPST, V.QTDDEVOLITEM, V.PISDEVOLITEM, V.COFINSDEVOLITEM, V.
				VLRDESPOPERACIONALITEMDEVOL, V.VLRTOTCOMISSAOITEMDEVOL, E.PERIRLUCRAT, E.PERCSLLLUCRAT, Y.CMDIACREDICMS, V.ICMSITEM, V.VLRFCPICMS, V.PERCPMF, V.PEROUTROIMPOSTO, V.ICMSDEVOLITEM, V.DVLRFCPICMS, CASE 
					WHEN ('N') = 'N'
						THEN (NVL(Y.CMDIAVLRDESCPISTRANSF, 0) + NVL(Y.CMDIAVLRDESCCOFINSTRANSF, 0) + NVL(Y.CMDIAVLRDESCICMSTRANSF, 0) + NVL(Y.CMDIAVLRDESCIPITRANSF, 0) + NVL(Y.CMDIAVLRDESCLUCROTRANSF, 0) + NVL(Y.CMDIAVLRDESCVERBATRANSF, 0))
					ELSE 0
					END, CASE 
					WHEN DV.UTILACRESCCUSTPRODRELAC = 'S' AND NVL(A.SEQPRODUTOBASE, A.SEQPRODUTOBASEANTIGO) IS NOT NULL
						THEN COALESCE(PR.PERCACRESCCUSTORELACVIG, NVL(F_RETACRESCCUSTORELACABC(V.SEQPRODUTO, V.DTAVDA), 1))
					ELSE 1
					END, 'N', 0, 0, 'S', V.VLRDESCMEDALHA, 'S', V.VLRDESCFORNEC, V.VLRDESCFORNECDEVOL, 'N', V.VLRFRETEITEMRATEIO, V.VLRFRETEITEMRATEIODEV, 'S', V.VLRICMSSTEMBUTPROD, V.VLRICMSSTEMBUTPRODDEV, V.VLREMBDESCRESSARCSTDEVOL, CASE 
					WHEN 'N' = 'S'
						THEN NVL(V.VLRDESCACORDOVERBAPDV, 0)
					ELSE 0
					END, NVL(Y.CMDIACREDIPI, 0), NVL(V.VLRITEMRATEIOCTE, 0), 'N', 'I', V.VLRIPIPRECOVDA, V.VLRIPIPRECODEVOL, V.VLRDESCMEDALHADEVOL, 'N')), 2) AS VLRLUCRO
	, SUM(V.ICMSITEM - V.ICMSDEVOLITEM) AS VLRICMS
	, SUM(V.VLRFCPICMS - V.DVLRFCPICMS) AS VLRFCP
	, SUM((V.PISITEM - V.PISDEVOLITEM)) AS VLRPIS
	, SUM((V.COFINSITEM - V.COFINSDEVOLITEM)) AS VLRCOFINS
	, SUM(V.VLRVERBAVDA - 0) AS VLRVERBAVDA
	, SUM((V.VLRVERBACOMPRA - V.VLRVERBACOMPRADEV) + (V.VLRVERBABONIFINCID - V.VLRVERBABONIFINCIDDEV) + (V.VLRVERBABONIFSEMINCID - V.VLRVERBABONIFSEMINCIDDEV)) AS VLRVERBASELLIN
	, SUM(((ROUND(V.VLRITEM, 2)) - (ROUND(V.VLRDEVOLITEM, 2) - (0))) + NVL(V.VLRDESCFORNEC, 0) + NVL(V.VLRDESCMEDALHA, 0) + NVL(VLREMBDESCRESSARCST, 0) - NVL(VLREMBDESCRESSARCSTDEVOL, 0)) AS VLRTOTLIQMARGEM
	, SUM(FC5_ABCDISTRIBCUSTOBRUTO('L', 'N', Y.CMDIAVLRNF - CASE 
				WHEN 'N' = 'S'
					THEN FC5_DIVIDE(FC5_DIVIDE(V.VLRDESCACORDOVERBAPDV, (V.QTDITEM - V.QTDDEVOLITEM)), V.QTDEMBALITEM)
				ELSE 0
				END, Y.CMDIAIPI, Y.CMDIAICMSST, Y.CMDIADESPNF, Y.CMDIADESPFORANF, Y.CMDIADCTOFORANF - NVL(Y.CMULTIMPOSTOPRESUM, 0), Y.CMDIACREDICMS, 'S', A.PROPQTDPRODUTOBASE, DECODE(V.ACMCOMPRAVENDA, 'N', 0, Y.QTDVERBAVDA), Y.VLRVERBAVDA, Y.QTDVDA, V.QTDITEM, V.QTDDEVOLITEM, CASE 
				WHEN ('N') = 'N'
					THEN (NVL(Y.CMDIAVLRDESCPISTRANSF, 0) + NVL(Y.CMDIAVLRDESCCOFINSTRANSF, 0) + NVL(Y.CMDIAVLRDESCICMSTRANSF, 0) + NVL(Y.CMDIAVLRDESCIPITRANSF, 0) + NVL(Y.CMDIAVLRDESCLUCROTRANSF, 0) + NVL(Y.CMDIAVLRDESCVERBATRANSF, 0) + NVL(Y.CMDIAVLRDESCDIFERENCATRANSF, 0))
				ELSE 0
				END, DECODE(V.ACMCOMPRAVENDA, 'N', 0, NVL(Y.VLRVERBAVDAACR, 0)), 'N', (
				CASE 
					WHEN DV.UTILACRESCCUSTPRODRELAC = 'S' AND NVL(A.SEQPRODUTOBASE, A.SEQPRODUTOBASEANTIGO) IS NOT NULL
						THEN COALESCE(PR.PERCACRESCCUSTORELACVIG, NVL(F_RETACRESCCUSTORELACABC(V.SEQPRODUTO, V.DTAVDA), 1))
					ELSE 1
					END
				))) AS VLRCTOBRUTO
	, SUM((ROUND(V.VLRITEM, 2)) - (ROUND(V.VLRDEVOLITEM, 2) - (0))) AS VLRVENDA
	, SUM(((ROUND(V.VLRITEM, 2)) - (ROUND(V.VLRDEVOLITEM, 2) - (0))) + NVL(VLREMBDESCRESSARCST, 0) - NVL(VLREMBDESCRESSARCSTDEVOL, 0)) AS VLRVENDALIQ
	, SUM((
			((Y.CMDIAVLRNF) + Y.CMDIAIPI - Y.CMDIACREDICMS - NVL(Y.CMDIACREDPIS, 0) - NVL(Y.CMDIACREDCOFINS, 0) - NVL(Y.CMDIACREDIPI, 0) + Y.CMDIAICMSST + Y.CMDIADESPNF + Y.CMDIADESPFORANF - Y.CMDIADCTOFORANF) * CASE 
				WHEN DV.UTILACRESCCUSTPRODRELAC = 'S' AND NVL(A.SEQPRODUTOBASE, A.SEQPRODUTOBASEANTIGO) IS NOT NULL
					THEN COALESCE(PR.PERCACRESCCUSTORELACVIG, NVL(F_RETACRESCCUSTORELACABC(V.SEQPRODUTO, V.DTAVDA), 1))
				ELSE 1
				END * DECODE('S', 'N', 1, NVL(A.PROPQTDPRODUTOBASE, 1)) - DECODE(V.ACMCOMPRAVENDA, 'N', 0, (DECODE(Y.QTDVERBAVDA, 0, 0, Y.VLRVERBAVDA * NVL(A.PROPQTDPRODUTOBASE, 1) / DECODE(NVL(Y.QTDVDA, 0), 0, Y.QTDVERBAVDA, Y.QTDVDA))) + DECODE(V.ACMCOMPRAVENDA, 'N', 0, DECODE('N', 'S', 0, (DECODE(NVL(Y.VLRVERBAVDAACR, 0), 0, 0, Y.VLRVERBAVDAACR * NVL(A.PROPQTDPRODUTOBASE, 1) / DECODE(NVL(Y.QTDVDA, 0), 0, 1, Y.QTDVDA))))))
			) * (V.QTDITEM - V.QTDDEVOLITEM)) AS VLRCTOLIQVDA
	,
	--SUM( ( ( V.VLRVERBAPDV - V.VLRVERBAPDVDEVOL ) * DECODE('S', 'N',1,NVL( A.PROPQTDPRODUTOBASE, 1) ) ) ) AS VLRVERBAPDV,
	ROUND(SUM(FC5_ABCDISTRIBCONTRIB('L', 'L', 'N', V.VLRITEM, 'N', V.VLRICMSST, V.VLRFCPST, V.VLRICMSSTEMPORIG, E.UF, V.UFPESSOA, 'N', 0, 'N', V.VLRIPIITEM, V.VLRIPIDEVOLITEM, 'N', V.VLRDESCFORANF, Y.CMDIAVLRNF - 0, Y.CMDIAIPI, NVL(Y.CMDIACREDPIS, 0), NVL(Y.CMDIACREDCOFINS, 0), Y.CMDIAICMSST, Y.CMDIADESPNF, Y.CMDIADESPFORANF, Y.CMDIADCTOFORANF, 'S', A.PROPQTDPRODUTOBASE, V.QTDITEM, V.VLREMBDESCRESSARCST, V.ACMCOMPRAVENDA, V.PISITEM, V.COFINSITEM, DECODE(V.TIPCGO, 'S', Y.QTDVDA, NVL(Y.QTDDEVOL, Y.QTDVDA)), (DECODE(V.TIPCGO, 'S', Y.VLRIMPOSTOVDA - NVL(Y.VLRIPIVDA, 0), NVL(Y.VLRIMPOSTODEVOL - NVL(V.VLRIPIDEVOLITEM, 0), Y.VLRIMPOSTOVDA - NVL(Y.VLRIPIVDA, 0)))), 'N', V.VLRDESPOPERACIONALITEM, Y.VLRDESPESAVDA, 'N', NVL(Y.VLRVERBAVDAACR, 0), V.QTDVERBAVDA, V.VLRVERBAVDA, 'N', NVL(V.VLRTOTCOMISSAOITEM, 0), V.VLRDEVOLITEM, VLRDEVOLICMSST, V.DVLRFCPST, V.QTDDEVOLITEM, V.PISDEVOLITEM, V.COFINSDEVOLITEM, V.VLRDESPOPERACIONALITEMDEVOL, V.VLRTOTCOMISSAOITEMDEVOL, E.PERIRLUCRAT, E.PERCSLLLUCRAT, Y.CMDIACREDICMS, V.ICMSITEM, V.VLRFCPICMS, V.PERCPMF, V.
				PEROUTROIMPOSTO, V.ICMSDEVOLITEM, V.DVLRFCPICMS, CASE 
					WHEN ('N') = 'N'
						THEN (NVL(Y.CMDIAVLRDESCPISTRANSF, 0) + NVL(Y.CMDIAVLRDESCCOFINSTRANSF, 0) + NVL(Y.CMDIAVLRDESCICMSTRANSF, 0) + NVL(Y.CMDIAVLRDESCIPITRANSF, 0) + NVL(Y.CMDIAVLRDESCLUCROTRANSF, 0) + NVL(Y.CMDIAVLRDESCVERBATRANSF, 0))
					ELSE 0
					END, CASE 
					WHEN DV.UTILACRESCCUSTPRODRELAC = 'S' AND NVL(A.SEQPRODUTOBASE, A.SEQPRODUTOBASEANTIGO) IS NOT NULL
						THEN COALESCE(PR.PERCACRESCCUSTORELACVIG, NVL(F_RETACRESCCUSTORELACABC(V.SEQPRODUTO, V.DTAVDA), 1))
					ELSE 1
					END, 'N', 0, 0, 'S', V.VLRDESCMEDALHA, 'S', V.VLRDESCFORNEC, V.VLRDESCFORNECDEVOL, 'N', V.VLRFRETEITEMRATEIO, V.VLRFRETEITEMRATEIODEV, 'S', V.VLRICMSSTEMBUTPROD, V.VLRICMSSTEMBUTPRODDEV, V.VLREMBDESCRESSARCSTDEVOL, CASE 
					WHEN 'N' = 'S'
						THEN NVL(V.VLRDESCACORDOVERBAPDV, 0)
					ELSE 0
					END, NVL(Y.CMDIACREDIPI, 0), 'N', 'I', V.VLRIPIPRECOVDA, V.VLRIPIPRECODEVOL, V.VLRDESCMEDALHADEVOL, 'N')), 2) AS VLRCONTRIB
--NVL(GP1.DESCRICAO,'** Sem Grupo de Promoções **') AS GRUPOPROMOCAO,
--DECODE( PR1.PROMOCAO, NULL, '** Sem Promocao **', PR1.PROMOCAO) AS PROMOCAO,   
--X.DESCSEGMENTO, 
--FCATEGORIAFAMILIANIVEL(PNSEQFAMILIA => A.SEQFAMILIA, PNNRODIVISAO => 1, PSNIVELHIERARQUIA => 2,PSTIPOCATEGORIA =>'M')AS SECAO,
--A.DESCCOMPLETA AS DESCRICAOPRODUTO ,
FROM MRL_CUSTODIAFAM Y
	, MAXV_ABCDISTRIBBASE V
	, MAP_PRODUTO A
	, MAP_PRODUTO PB
	, MAP_FAMDIVISAO D
	, MAP_FAMEMBALAGEM K
	, MAX_EMPRESA E
	, MAX_DIVISAO DV
	, MAP_PRODACRESCCUSTORELAC PR
	, MAD_FAMSEGMENTO H
	, MAXV_ABCPROMOCAO_DISTINCT PR1
	, MRL_GRUPOPROMOCAO GP1
	, MRL_PROMOCAOITEM PR2
	, MAD_SEGMENTO X
WHERE D.SEQFAMILIA = A.SEQFAMILIA AND V.NROSEGMENTO = X.NROSEGMENTO AND V.SEQPROMOCAO = PR2.SEQPROMOCAO(+) AND V.NROEMPRESA = PR2.NROEMPRESA(+) AND V.SEQPRODUTO = PR2.SEQPRODUTO(+) AND V.QTDEMBALITEM = PR2.QTDEMBALAGEM(+) AND H.NROSEGMENTO = PR2.NROSEGMENTO(+) AND D.NRODIVISAO = V.NRODIVISAO AND V.SEQPRODUTO = A.SEQPRODUTO AND V.SEQPRODUTOCUSTO = PB.SEQPRODUTO AND V.NRODIVISAO = D.NRODIVISAO AND E.NROEMPRESA = V.NROEMPRESA AND E.NRODIVISAO = DV.NRODIVISAO AND V.SEQPRODUTO = PR.SEQPRODUTO(+) AND V.DTAVDA = PR.DTAMOVIMENTACAO(+) AND Y.NROEMPRESA = NVL(E.NROEMPCUSTOABC, E.NROEMPRESA) AND Y.DTAENTRADASAIDA = V.DTAVDA AND K.SEQFAMILIA = A.SEQFAMILIA AND K.QTDEMBALAGEM = 1 AND Y.SEQFAMILIA = PB.SEQFAMILIA AND H.SEQFAMILIA = PB.SEQFAMILIA AND H.NROSEGMENTO = V.NROSEGMENTO AND PR1.SEQPRODUTO(+) = V.SEQPRODUTO AND PR1.NROEMPRESA(+) = V.NROEMPRESA AND PR1.NROSEGMENTO(+) = V.NROSEGMENTO AND PR1.SEQPROMOCAO(+) = V.SEQPROMOCAO AND PR1.SEQGRUPOPROMOC = GP1.SEQGRUPOPROMOC(+) AND PR1.DTAGERACAO(+) IS NOT NULL AND PR1.QTDEMBALAGEM(+) = V.QTDEMBALITEM AND DECODE(V.TIPTABELA, 'S', V.CGOACMCOMPRAVENDA, V.ACMCOMPRAVENDA) IN (
		'S'
		, 'I'
		) AND (
		(
			PR1.NROTABVENDA IS NOT NULL AND EXISTS (
				SELECT 1
				FROM MAD_PEDVENDAITEM X
					, MAD_PEDVENDA Y
				WHERE X.NROPEDVENDA = Y.NROPEDVENDA AND X.NROEMPRESA = Y.NROEMPRESA AND X.NUMERODF = V.NRODOCTO AND X.SERIEDF = V.SERIEDOCTO AND X.NROSERIEECF = V.NROSERIEECF AND X.NROEMPRESADF = V.NROEMPRESA AND X.SEQPRODUTO = V.SEQPRODUTO AND NVL(X.NROTABVENDA, Y.NROTABVENDA) = PR1.NROTABVENDA
				)
			) OR PR1.NROTABVENDA IS NULL
		) 
-- AND A.SEQPRODUTO = 52 
-- AND V.NROSEGMENTO = 1 
-- AND V.NROEMPRESA IN (20) 
-- AND (V.DTAVDA BETWEEN TO_DATE( ? , 'dd/mm/yyyy') AND TO_DATE( ? , 'dd/mm/yyyy'))
-- AND (V.DTAVDA BETWEEN TO_DATE('01/03/2025','dd/mm/yyyy') AND TO_DATE('31/03/2025','dd/mm/yyyy')) OR   V.DTAVDA BETWEEN TO_DATE('25/02/2024','dd/mm/yyyy') AND TO_DATE('26/02/2024','dd/mm/yyyy')) 
-- AND (TRUNC(V.DTAVDA) BETWEEN  ? + 1     AND TRUNC(SYSDATE)-1 OR V.DTAVDA = TRUNC(ADD_MONTHS(SYSDATE, -12) - 1))   
-- AND V.DTAVDA IN (TRUNC(SYSDATE - 1), TRUNC(ADD_MONTHS(SYSDATE, -12) - 1))
-- AND V.DTAVDA >= ?
   AND V.DTAVDA BETWEEN ? AND ?
GROUP BY 
      V.NROEMPRESA
	, V.DTAVDA
	, V.NROSEGMENTO
	, A.SEQFAMILIA
	, PR1.SEQPROMOCAO
	, GP1.SEQGRUPOPROMOC
	, A.SEQPRODUTO
	, K.QTDEMBALAGEM
	--,TO_CHAR(DTAHORLANCTO,'hh24')</sql>
