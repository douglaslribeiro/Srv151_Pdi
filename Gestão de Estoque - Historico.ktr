    <connection>CONSINCO 242</connection>
    <sql>WITH ULTIMA_MOVIMENTACAO AS
  (
    SELECT
      SEQPRODUTO,
      NROEMPRESA,
      MAX(DTAENTRADASAIDA) AS ULTIMADATA
    FROM
      MRL_CUSTODIA
    WHERE
      NROEMPRESA BETWEEN ? AND ?
    AND DTAENTRADASAIDA BETWEEN TRUNC(ADD_MONTHS(SYSDATE, -1), 'MM') AND LAST_DAY(ADD_MONTHS(SYSDATE, -1))
    GROUP BY
      SEQPRODUTO,
      NROEMPRESA )
SELECT
  A.NROEMPRESA,
  A.SEQPRODUTO,
  B.ULTIMADATA,
  QTDESTQINICIAL + QTDENTRADA - QTDSAIDA AS SALDO_DIA
FROM
  MRL_CUSTODIA A
INNER JOIN
  ULTIMA_MOVIMENTACAO B
ON
  A.SEQPRODUTO   = B.SEQPRODUTO
AND A.NROEMPRESA = B.NROEMPRESA
AND B.ULTIMADATA = A.DTAENTRADASAIDA
</sql>
    <limit>0</limit>
    <lookup>Filiais 1 a 41</lookup>
