    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>WITH vendas_periodo AS (
    SELECT 
        c.nroempresa,
        c.seqproduto,
        SUM(c.qtdvda - c.qtddevol) AS qtdvda,
        SUM(c.vlrtotalvda - c.vlrtotaldevol) AS vlrtotalvda
    FROM mrl_custodia c
    WHERE c.dtaentradasaida >= TRUNC(SYSDATE) - 90
      AND c.dtaentradasaida &lt; TRUNC(SYSDATE)
    GROUP BY c.nroempresa, c.seqproduto
),
vendas_empresa AS (
    SELECT 
        cf.nroempresa,
        SUM(cf.vlrtotalvda - cf.vlrtotaldevol) AS vlrtotalvda
    FROM mrl_custodiafam cf
    WHERE cf.dtaentradasaida >= TRUNC(SYSDATE) - 90
      AND cf.dtaentradasaida &lt; TRUNC(SYSDATE)
    GROUP BY cf.nroempresa
)
SELECT 
    e.nroempresa,
    e.seqproduto,
    NVL(v.qtdvda, 0) AS qtdvda,
    NVL(v.vlrtotalvda, 0) AS vlrtotalvda,
    ROUND(
        (NVL(v.vlrtotalvda, 0) / NULLIF(NVL(ve.vlrtotalvda, 0), 0)) * 100,
        4
    ) AS percentind,
    SUM(
        (NVL(v.vlrtotalvda, 0) / NULLIF(NVL(ve.vlrtotalvda, 0), 0)) * 100
    ) OVER (
        PARTITION BY e.nroempresa
        ORDER BY NVL(v.vlrtotalvda, 0) DESC NULLS LAST
    ) AS percentacum
FROM map_produto a
INNER JOIN map_familia b ON a.seqfamilia = b.seqfamilia
INNER JOIN map_famdivisao c ON a.seqfamilia = c.seqfamilia 
                            AND c.finalidadefamilia = 'R'
INNER JOIN mad_famsegmento d ON a.seqfamilia = d.seqfamilia 
                             AND d.status = 'A'
INNER JOIN mrlv_produtoempresa e ON a.seqproduto = e.seqproduto
INNER JOIN max_empresa f ON c.nrodivisao = f.nrodivisao 
                         AND d.nrosegmento = f.nrosegmentoprinc 
                         AND e.nroempresa = f.nroempresa
LEFT JOIN vendas_periodo v ON e.nroempresa = v.nroempresa 
                           AND e.seqproduto = v.seqproduto
LEFT JOIN vendas_empresa ve ON e.nroempresa = ve.nroempresa
-- WHERE e.nroempresa = 11  -- Descomente se necessário filtrar por empresa
ORDER BY e.nroempresa, NVL(v.vlrtotalvda, 0) DESC NULLS LAST



-- Versão Não otimizada 04.03.2026
/*
select
       j.nroempresa
     , j.seqproduto
     , j.qtdvda
     , j.vlrtotalvda
     , j.percentind
     , sum(j.percentind) over
                              (
                                  partition by j.nroempresa
                                  order by j.nroempresa
                                    , j.vlrtotalvda desc nulls last
                              )
       as percentacum
from
       (
              select
                     e.nroempresa
                   , e.seqproduto
                   , nvl(h.qtdvda,0)                                             qtdvda
                   , nvl(h.vlrtotalvda,0)                                        vlrtotalvda
                   , (fc5_divide(nvl(h.vlrtotalvda,0),nvl(g.vlrtotalvda,0))*100) as percentind
              from
                     map_produto        a
                   , map_familia        b
                   , map_famdivisao     c
                   , mad_famsegmento    d
                   , mrlv_produtoempresa e
                   , max_empresa        f
                   , (
                            select
                                   mrl_custodiafam.nroempresa
                                 , sum(mrl_custodiafam.vlrtotalvda - mrl_custodiafam.vlrtotaldevol) vlrtotalvda
                            from
                                   mrl_custodiafam
                            where
                                   mrl_custodiafam.dtaentradasaida between trunc(sysdate -90) and trunc(sysdate -1)
                            group by
                                   mrl_custodiafam.nroempresa) g
                   , (
                            select
                                   mrl_custodia.nroempresa
                                 , mrl_custodia.seqproduto
                                 , sum(mrl_custodia.qtdvda      - mrl_custodia.qtddevol)      qtdvda
                                 , sum(mrl_custodia.vlrtotalvda - mrl_custodia.vlrtotaldevol) vlrtotalvda
                            from
                                   mrl_custodia
                            where
                                   mrl_custodia.dtaentradasaida between trunc(sysdate -90) and trunc(sysdate -1)
                            group by
                                   mrl_custodia.nroempresa
                                 , mrl_custodia.seqproduto) h
              where
                     a.seqfamilia        = b.seqfamilia
              and    a.seqfamilia        = c.seqfamilia
              and    c.finalidadefamilia = 'R'
              and    a.seqfamilia        = d.seqfamilia
              and    d.status            = 'A'
              and    a.seqproduto        = e.seqproduto
              and    c.nrodivisao        = f.nrodivisao
              and    d.nrosegmento       = f.nrosegmentoprinc
              and    e.nroempresa        = f.nroempresa
              and    e.nroempresa        = g.nroempresa(+)
              and    e.nroempresa        = h.nroempresa(+)
              and    e.seqproduto        = h.seqproduto(+)
              --and    e.nroempresa        = 11
		 ) j
*/</sql>
