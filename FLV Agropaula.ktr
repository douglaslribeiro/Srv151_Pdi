    <sql>with temp_01 as
  (
    SELECT
      data_atualizacao  ,
      nome_transformacao,
      seqsimilaridade   ,
      descsimilaridade  ,
      seqproduto        ,
      status            ,
      dtahorainclusao
    FROM
      public.dim_lista_padrao
    where
      seqsimilaridade = 229 )
SELECT
  a.seqproduto   ,
--  a.departamento ,
--  a.secao        ,
--  a.grupo        ,
--  a.subgrupo     ,
  a.desccompleta
--  a.descreduzida
FROM
  public.dim_produto a
inner join
  temp_01 b
on
  a.seqproduto = b.seqproduto</sql>
