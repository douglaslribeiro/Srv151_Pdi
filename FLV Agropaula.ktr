  <step>
    <name>FLV AgroPaula 2025</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>BI 238 DW</connection>
    <sql>with temp_01 as
  (
    SELECT
      data_atualizacao  ,
      nome_transformacao,
      seqsimilaridade   ,
      descsimilaridade  ,
      seqproduto        ,
      status            ,
      dtahorainclusao
    FROM
      public.dim_lista_padrao
    where
      seqsimilaridade = ? )
--select  * from  temp_01
SELECT
  --  a.seqpromocao    ,
  --  a.seqgrupopromoc ,
  a.dtmovimento ,
  a.nroempresa  ,
  --  a.nrosegmento    ,
  a.seqproduto ,
  a.quantidade ,
  -- a.nrodoctos      ,
  -- a.nroclientes    ,
  -- a.vlrvendaliq ,
  EXTRACT(DOW FROM a.dtmovimento) as diadasemana
  /*
  a.vlrvendapromoc ,
  a.vlrlucro       ,
  a.vlricms        ,
  a.vlrfcp         ,
  a.vlrpis         ,
  a.vlrcofins      ,
  a.vlrverbavda    ,
  a.vlrverbasellin ,
  a.vlrtotliqmargem,
  a.nroitens       ,
  a.vlrctobruto    ,
  a.vlrvenda       ,
  a.vlrctoliqvda   ,
  a.vlrcontrib     ,
  a.qtdembalagem
*/
FROM
  public.fat_venda a
inner join
  temp_01 b
on
  a.seqproduto    = b.seqproduto
and a.dtmovimento >= CURRENT_DATE - INTERVAL '31 days'
and EXTRACT(DOW FROM a.dtmovimento) = EXTRACT(DOW FROM CURRENT_DATE)
order by  2, 1, 3</sql>
    <limit>0</limit>
    <lookup>Lista Padrão</lookup>
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
