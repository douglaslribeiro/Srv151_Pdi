    <connection>CONSINCO</connection>
    <sql>SELECT 
    SYSDATE AS DT_HR_EXTRACAO, 
	DTAMOVIMENTO, 
	NROEMPRESA, 
	AVG(QTD_ITEM_CUPOM) MEDIA_ITEM_CUPOM, 
	SUM(VLRTOTAL) VLRTOTAL, 
	COUNT(DISTINCT NROCHECKOUT || COO) COO 
FROM qview_cia_baseprodutividade
WHERE 
       DTAMOVIMENTO >= TRUNC(SYSDATE)     
AND 
       DTAMOVIMENTO &lt; TRUNC(SYSDATE) + 1
AND 
	   NROEMPRESA NOT IN (5,6,28)
AND
	   NROEMPRESA BETWEEN 1 AND 99
GROUP BY DTAMOVIMENTO, NROEMPRESA    
ORDER BY NROEMPRESA</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
