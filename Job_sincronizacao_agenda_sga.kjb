    <entry>
      <name>SQL para inserir cliente</name>
      <description/>
      <type>SQL</type>
      <attributes/>
      <sql>INSERT INTO novosgaDB.clientes (nome, documento, email, telefone)
SELECT
    a.nome,
    a.doc,
    a.email,
    a.telefone
FROM
    novosgaDB.tmp_agenda a
LEFT JOIN
    novosgaDB.clientes b ON a.doc = b.documento
WHERE
    b.documento IS NULL
    AND a.doc IS NOT NULL</sql>
