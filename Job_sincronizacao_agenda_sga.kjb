    <entry>
      <name>SQL para atualizar funcionarios</name>
      <description/>
      <type>SQL</type>
      <attributes/>
      <sql>INSERT INTO novosgaDB.clientes (
    nome,
    documento,
    telefone,
    dt_nascimento,
    genero,
    observacao,
    end_cep,
    end_logradouro,
    end_numero
)
SELECT 
    f.nmpessoa,
    f.cpf,
    CONCAT(f.foneddd1, f.fonenro1),
    DATE(f.dtnascimento),
    f.sexo,
    CONCAT(
        'Status: ', f.status, CHAR(10),
        'Setor: ', f.setor, CHAR(10),
        'Função: ', f.funcao, CHAR(10),
        'Matrícula: ', f.matricula
    ),
    f.cep,
    f.complementologradouro,
    f.nrologradouro
FROM novosgaDB.tmp_funcionarios f
WHERE f.cpf IS NOT NULL
ON DUPLICATE KEY UPDATE
    nome           = IF(nome != VALUES(nome), VALUES(nome), nome),
    telefone       = IF(telefone IS NULL OR telefone = '', VALUES(telefone), telefone),
    dt_nascimento  = IF(dt_nascimento != VALUES(dt_nascimento), VALUES(dt_nascimento), dt_nascimento),
    genero         = IF(genero != VALUES(genero), VALUES(genero), genero),
    observacao     = IF(observacao != VALUES(observacao), VALUES(observacao), observacao),
    end_cep        = IF(end_cep != VALUES(end_cep), VALUES(end_cep), end_cep),
    end_logradouro = IF(end_logradouro != VALUES(end_logradouro), VALUES(end_logradouro), end_logradouro),
    end_numero     = IF(end_numero != VALUES(end_numero), VALUES(end_numero), end_numero);
</sql>
      <useVariableSubstitution>F</useVariableSubstitution>
      <sqlfromfile>F</sqlfromfile>
      <sqlfilename/>
      <sendOneStatement>F</sendOneStatement>
      <connection>Sga</connection>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>512</xloc>
      <yloc>464</yloc>
      <attributes_kjc/>
    </entry>
