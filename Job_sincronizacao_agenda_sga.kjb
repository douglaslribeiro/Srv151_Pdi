    <entry>
      <name>SQL para inserir agendamento</name>
      <description/>
      <type>SQL</type>
      <attributes/>
      <sql>INSERT INTO novosgaDB.agendamentos (
    cliente_id,
    unidade_id,
    servico_id,
    `data`,
    hora,
    situacao
)
SELECT
   b.id  AS cliente_id,
   1     AS unidade_id,
   c.id  AS servico_id,
   a.dta AS `data`,
   a.hora,
   a.status AS situacao
FROM
   novosgaDB.tmp_agenda a
JOIN
   novosgaDB.clientes b ON a.doc = b.documento
JOIN
   novosgaDB.servicos c ON a.infoagenda = c.nome
LEFT JOIN
   novosgaDB.agendamentos ag ON
       ag.cliente_id = b.id AND
       ag.unidade_id = 1 AND
       ag.servico_id = c.id AND
       ag.`data` = a.dta AND
       ag.hora = a.hora AND
       ag.situacao = a.status
WHERE
   ag.cliente_id IS NULL
and a.status = 'agendado'</sql>
      <useVariableSubstitution>F</useVariableSubstitution>
