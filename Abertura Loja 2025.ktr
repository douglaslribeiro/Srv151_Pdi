    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>select a.nropedidosuprim,
       a.nroempresa,
       a.centralloja,
       a.seqcomprador,
       a.seqfornecedor,
       a.tippedidosuprim,
       a.situacaoped,
       a.qtdtotsolicitada,
       a.qtdtotrecebida,
       a.qtdtotcancelada,
       a.qtdtottransito,
       a.vlrtotpedido,
       a.vlrtotcancelado,
       a.vlrtotrecebido
from msu_pedidosuprim a
where  a.nroempresa      = ?
and a.dtahorinclusao >= TO_DATE('01-10-2025', 'DD-MM-YYYY')</sql>
    <limit>0</limit>
    <lookup>LojaDestino</lookup>
