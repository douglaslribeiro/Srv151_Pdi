  <step>
    <name>Mix Loja</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>SELECT
  E.NROEMPRESA                                ,
  FNNOMEEMPRESAREDUZIDO(E.NROEMPRESA) EMPRESA ,
  B.SEQCOMPRADOR                              ,
  FNNOMECOMPRADOR(A.SEQFAMILIA,1) COMPRADOR   ,
  D.CATEGORIA                                 ,
  D.CAMINHOCOMPLETO                           ,
  A.SEQFAMILIA                                ,
  A.SEQPRODUTO                                ,
  A.DESCCOMPLETA                              ,
  B.FORMAABASTECIMENTO                        ,
  F.DESCRICAO                                 ,
  DECODE(E.STATUSCOMPRA,
         'A'           ,'ATIVO',
         'INATIVO') STATUSCOMPRA ,
  SYSDATE           AS DATAHORAATUALIZACAO
FROM
  MAP_PRODUTO A
INNER JOIN
  MAP_FAMDIVISAO B
ON
  A.SEQFAMILIA = B.SEQFAMILIA
INNER JOIN
  MAP_FAMDIVCATEG C
ON
  B.SEQFAMILIA   = C.SEQFAMILIA
AND B.NRODIVISAO = C.NRODIVISAO
INNER JOIN
  MAP_CATEGORIA D
ON
  C.SEQCATEGORIA = D.SEQCATEGORIA
AND C.NRODIVISAO = D.NRODIVISAO
INNER JOIN
  MRLV_PRODUTOEMPRESA E
ON
  A.SEQPRODUTO = E.SEQPRODUTO
INNER JOIN
  MAP_FORMAABASTEC F
ON
  B.FORMAABASTECIMENTO = F.FORMAABASTECIMENTO
WHERE
  B.NRODIVISAO        = 1
AND C.STATUS          = 'A'
AND D.NIVELHIERARQUIA >= 4
AND (
    E.NROEMPRESA in (?))
</sql>
