  <step>
    <name>Compras e Transferencias</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO 2025</connection>
    <sql>select a.seqgercompra,
       a.nropedfornecedor,
       a.nropedidosuprim,
       a.dtarecebto,
       a.seqcomprador,
       a.tippedidosuprim,
       a.empresa_origem,
       a.empresa_destino nroempresa,
       a.centralloja,
       a.seqproduto,
       a.embalagem,
       a.statusitem,
       a.situacaoped,
       a.dtaemissao,
       a.qtdsolicitada,
       c.qtdexpedida,
       c.qtdcorteetqvol,
       c.qtdcortepedvenda,
       a.qtdrecebida,
       a.qtdcancelada,
       a.qtdtransito,
       a.qtdembalagem,
       a.vlrembitem,
       a.vlritem,
       a.dtahorinclusao,
       c.nropedvenda,
       nvl(a.numeronf,d.numerodf) numeronf,
       nvl(a.serienf,d.seriedf)serienf,
       nvl(c.dtahorcancelamento,a.dtahorcancelamento) dtahorcancelamento
from qview_base_acomp_transf a
left join qview_base_acomp_transf_exp c on a.nropedidosuprim = c.nropedidosuprim
                                       and a.empresa_origem   = c.nroempresa
                                       and a.empresa_destino  = c.nroempdestino
                                       and a.seqproduto       = c.seqproduto  
                                       and a.qtdembalagem     = c.qtdembalagem                                    
inner join max_comprador b on a.seqcomprador = b.seqcomprador
left join mad_pedvendaitem d on c.nroempresa = d.nroempresa
                            and c.nropedvenda = d.nropedvenda
                            and c.seqproduto  = d.seqproduto
                            and c.qtdembalagem = d.qtdembalagem
where a.empresa_destino = (?)
and a.dtahorinclusao >= TO_DATE('01-10-2025', 'DD-MM-YYYY')</sql>
    <limit>0</limit>
    <lookup>LojaDestino</lookup>
    <execute_each_row>N</execute_each_row>
