    <connection>alfresco</connection>
    <sql>SELECT
   "ID do Processo"               ,
   "ID da Tarefa"                 ,
   "Descrição"                    ,
   "Tipo de Tarefa"               ,
   "Solicitante"                  ,
   "Usuário Solicitante"          ,
   "Setor do Solicitante"         ,
   "Cargo do Solicitante"         ,
   "E-mail do Solicitante"        ,
   "Gerente do Solicitante"       ,
   "Cargo do Gerente"             ,
   "E-mail do Gerente"            ,
   "Designado"                    ,
   "Usuário Responsável"          ,
   "Setor do Designado"           ,
   "Cargo do Designado"           ,
   "E-mail do Designado"          ,
   "Gerente do Designado"         ,
   "Cargo do Gerente (Designado)" ,
   "E-mail do Gerente (Designado)",
   "Status do Processo"           ,
   "Status da Tarefa"             ,
   "Prioridade"                   ,
   "Data de Início"               ,
   "Prazo Final"                  ,
   "Dias Restantes"               ,
   "Situação do Prazo"            ,
   "Conclusão do Prazo"           ,
   "Data de Conclusão"            ,
   "Link para Detalhes"           ,
   start_act_id_                  ,
   end_act_id_                    ,
   prioridade_num                 ,
   inicio_do_processo_original    ,
   duracao_total                  ,
   nome_processo                  ,
   descricao_atual_tarefa         ,
   descricao_original_processo
FROM
   public.view_workflow_metabase
WHERE "Data de Início" &lt; DATE_TRUNC('month', CURRENT_DATE)</sql>
