  <step>
    <name>dim_lojas</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONSINCO</connection>
    <sql>WITH LOJAS AS
  (
    SELECT DISTINCT
      XX.DESCRICAO AS REGIONAL,
      LL.NRODIVISAO           ,
      ZZ.NOMEREDUZIDO         ,
      ZZ.NROEMPRESA           ,
      ZZ.FANTASIA             ,
      ZZ.RAZAOSOCIAL          ,
      ZZ.ENDERECO             ,
      ZZ.BAIRRO               ,
      ZZ.CEP                  ,
      ZZ.CIDADE               ,
      ZZ.ESTADO               ,
      ZZ.PAIS                 ,
      ZZ.NROCGC               ,
      ZZ.DIGCGC               ,
      ZZ.MATRIZ               ,
      ZZ.ENDERECONRO          ,
      ZZ.SEQCIDADE            ,
      ZZ.SEQBAIRRO            ,
      ZZ.SEQLOGRADOURO        ,
      ZZ.NROEMPSEGURANCA      ,
      ZZ.SEQPESSOA            ,
      ZZ.STATUS
    FROM
      MAX_ATRIBUTOFIXO XX,
      MAX_EMPRESAPORTE YY,
      GE_EMPRESA       ZZ,
      max_empresa      ll
    WHERE
      XX.LISTA             = YY.PORTEEMPRESA
    AND YY.NROEMPRESA      = ZZ.NROEMPRESA
    AND YY.STATUS          = 'A'
    AND XX.TIPATRIBUTOFIXO = 'PORTE_EMPRESA' --order by 2
    AND XX.DESCRICAO       LIKE 'REG %'
    and LL.NROEMPRESA      = YY.PORTEEMPRESA ),
  LOJAS_2 AS
  (
    SELECT
      CASE
      WHEN
        B.PORTEEMPRESA = 8
      THEN
        'Sim'
      ELSE
        'Não'
      END IFOOD,
      A.*
    FROM
      LOJAS A
    LEFT JOIN
      max_empresaporte B
    ON
      A.NROEMPRESA     = B.NROEMPRESA
    AND B.PORTEEMPRESA = '8'
    ORDER BY
      A.NROEMPRESA )
SELECT
  A.NROEMPRESA      ,
  A.NOMEREDUZIDO    ,
  A.NROEMPRESA      ,
  B.NRODIVISAO      ,
  A.FANTASIA        ,
  A.RAZAOSOCIAL     ,
  A.ENDERECO        ,
  A.BAIRRO          ,
  A.CEP             ,
  A.CIDADE          ,
  A.ESTADO          ,
  A.PAIS            ,
  A.NROCGC          ,
  A.DIGCGC          ,
  A.MATRIZ          ,
  A.ENDERECONRO     ,
  A.SEQCIDADE       ,
  A.SEQBAIRRO       ,
  A.SEQLOGRADOURO   ,
  A.NROEMPSEGURANCA ,
  A.SEQPESSOA       ,
  B.IFOOD           ,
  B.REGIONAL        ,
  case
  when
    A.NROEMPRESA &lt;=99
  THEN
    'Grupo Alvorada'
  ELSE
    'Outros'
  end GRUPO
FROM
  GE_EMPRESA A
LEFT JOIN
  LOJAS_2 B
ON
  A.NROEMPRESA = B.NROEMPRESA
ORDER BY
  A.NROEMPRESA</sql>
    <limit>0</limit>
